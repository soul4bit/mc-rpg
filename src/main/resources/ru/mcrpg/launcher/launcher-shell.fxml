                                                        <Region styleClass="ornament-line"/>
                                                    </children>
                                                </HBox>
                                                <Label text="OBSIDIANGATE" styleClass="hero-title"/>
                                                <HBox alignment="CENTER" spacing="18.0">
                                                    <children>
                                                        <Region styleClass="subtitle-line"/>
                                                        <Label text="MINECRAFT RPG ПРИКЛЮЧЕНИЕ" styleClass="hero-subtitle"/>
                                                        <Region styleClass="subtitle-line"/>
                                                    </children>
                                                </HBox>
                                                <Label maxWidth="620.0"
                                                       text="Погрузись в мир магии, древних&#10;тайн и бесконечных приключений."
                                                       textAlignment="CENTER" wrapText="true"
                                                       styleClass="hero-description"/>
                                                <Button fx:id="launchButton" alignment="CENTER" contentDisplay="LEFT"
                                                        mnemonicParsing="false" styleClass="play-button" text="ИГРАТЬ">
                                                    <graphic>
                                                        <SVGPath content="M14.6 5.1 L20 4 L18.9 9.4 L8.7 19.6 L4.4 15.3 Z M6.8 17.2 L3.8 20.2 M7.2 13.6 L10.4 16.8 M11.8 7.9 L16.1 12.2"
                                                                 fill="TRANSPARENT" scaleX="1.58" scaleY="1.58"
                                                                 stroke="#F6ECFF" strokeLineCap="ROUND" strokeLineJoin="ROUND"
                                                                 strokeWidth="1.8"/>
                                                    </graphic>
                                                </Button>

                                                <VBox maxWidth="640.0" spacing="12.0" styleClass="sync-panel">
                                                    <children>
                                                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                                                            <children>
                                                                <Label fx:id="syncStatusLabel" text="Готово к запуску"
                                                                       styleClass="sync-status"/>
                                                                <Region HBox.hgrow="ALWAYS"/>
                                                                <Label fx:id="syncPercentLabel" text="ГОТОВО"
                                                                       styleClass="sync-percent"/>
                                                            </children>
                                                        </HBox>
                                                        <Label fx:id="syncFileLabel" styleClass="sync-file" wrapText="true"/>
                                                        <ProgressBar fx:id="syncProgressBar" maxWidth="1.7976931348623157E308"
                                                                     progress="0.0" styleClass="launcher-progress"/>
                                                        <HBox alignment="CENTER_LEFT" spacing="14.0">
                                                            <children>
                                                                <Button fx:id="syncButton" alignment="CENTER"
                                                                        contentDisplay="LEFT" mnemonicParsing="false"
                                                                        styleClass="secondary-action-button"
                                                                        text="Синхронизировать">
