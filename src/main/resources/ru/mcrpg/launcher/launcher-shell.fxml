<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ru.mcrpg.launcher.LauncherShellController"
            prefHeight="780.0" prefWidth="1180.0" styleClass="shell-root">
    <top>
        <HBox alignment="CENTER_LEFT" onMouseDragged="#dragWindow" onMousePressed="#captureWindowDrag"
              spacing="12.0" styleClass="top-bar">
            <padding>
                <Insets bottom="10.0" left="14.0" right="10.0" top="10.0"/>
            </padding>
            <children>
                <VBox spacing="2.0">
                    <children>
                        <Label fx:id="brandLogoLabel" styleClass="app-title" text="ObsidianGate"/>
                        <Label fx:id="brandSubtitleLabel" styleClass="app-subtitle" text="Launcher"/>
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="sidebarVersionLabel" styleClass="top-meta" text="Launcher"/>
                <Button mnemonicParsing="false" onAction="#minimizeWindow" styleClass="window-button" text="_"/>
                <Button mnemonicParsing="false" onAction="#closeWindow" styleClass="window-button" text="X"/>
            </children>
        </HBox>
    </top>

    <left>
        <VBox prefWidth="220.0" spacing="8.0" styleClass="sidebar">
            <padding>
                <Insets bottom="14.0" left="14.0" right="14.0" top="14.0"/>
            </padding>
            <children>
                <Label styleClass="section-title" text="Навигация"/>
                <Button disable="true" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Главная"/>
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#openProfileScreen"
                        text="Профиль"/>

                <Region VBox.vgrow="ALWAYS"/>

                <VBox spacing="5.0" styleClass="plain-block">
                    <children>
                        <Label styleClass="section-title" text="Профиль"/>
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <children>
                                <Label fx:id="profileNameLabel" styleClass="value-label" text="Гость"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="profileChevronLabel" styleClass="muted" text="⌄"/>
                            </children>
                        </HBox>
                        <Label fx:id="profileRankLabel" styleClass="muted" text="Не авторизован"/>
                    </children>
                </VBox>
            </children>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="content-scroll">
            <content>
                <VBox spacing="14.0" styleClass="content">
                    <padding>
                        <Insets bottom="18.0" left="18.0" right="18.0" top="18.0"/>
                    </padding>
                    <children>
                        <HBox fx:id="launcherUpdateCard" alignment="CENTER_LEFT" managed="false" spacing="12.0"
                              styleClass="section" visible="false">
                            <children>
                                <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label fx:id="launcherUpdateTitleLabel" styleClass="section-title"
                                               text="Доступно обновление лаунчера"/>
                                        <Label fx:id="launcherUpdateDescriptionLabel" styleClass="muted"
                                               text="Новая версия будет скачана и установлена автоматически."
                                               wrapText="true"/>
                                    </children>
                                </VBox>
                                <Button fx:id="launcherUpdateButton" mnemonicParsing="false" text="Обновить"/>
                            </children>
                        </HBox>

                        <VBox spacing="10.0" styleClass="section">
                            <children>
                                <Label styleClass="section-title" text="Запуск"/>
                                <HBox spacing="10.0">
                                    <children>
                                        <Button fx:id="launchButton" maxWidth="1.7976931348623157E308"
                                                mnemonicParsing="false" styleClass="primary-button" text="Играть"
                                                HBox.hgrow="ALWAYS"/>
                                        <Button fx:id="syncButton" mnemonicParsing="false" text="Синхронизировать"/>
                                        <Button fx:id="previewButton" mnemonicParsing="false" text="Предпросмотр"/>
                                    </children>
                                </HBox>

                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Label fx:id="syncStatusLabel" styleClass="value-label" text="Готово к запуску"/>
                                        <Label fx:id="syncPercentLabel" styleClass="muted" text="0%"/>
                                    </children>
                                </HBox>
                                <ProgressBar fx:id="syncProgressBar" maxWidth="1.7976931348623157E308"
                                             progress="0.0"/>
                                <Label fx:id="syncFileLabel" wrapText="true"/>
                                <Label fx:id="syncBytesLabel" styleClass="muted" wrapText="true"/>
                                <Label fx:id="previewSummaryLabel" styleClass="muted" wrapText="true"/>
                                <VBox fx:id="previewChangesBox" spacing="8.0"/>
                            </children>
                        </VBox>

                        <VBox spacing="10.0" styleClass="section">
                            <children>
                                <Label styleClass="section-title" text="Сервер"/>
                                <GridPane hgap="12.0" vgap="8.0">
                                    <children>
                                        <Label styleClass="muted" text="Маршрут" GridPane.columnIndex="0"
                                               GridPane.rowIndex="0"/>
                                        <Label fx:id="serverRouteValueLabel" text="-" wrapText="true"
                                               GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                                        <Label styleClass="muted" text="Статус" GridPane.columnIndex="0"
                                               GridPane.rowIndex="1"/>
                                        <HBox alignment="CENTER_LEFT" spacing="8.0" GridPane.columnIndex="1"
                                              GridPane.rowIndex="1">
                                            <children>
                                                <Region fx:id="serverPresenceIndicator" prefHeight="10.0"
                                                        prefWidth="10.0"
                                                        styleClass="presence-indicator, presence-checking"/>
                                                <Label fx:id="serverPresenceLabel" text="ПРОВЕРКА"/>
                                            </children>
                                        </HBox>

                                        <Label styleClass="muted" text="Онлайн" GridPane.columnIndex="0"
                                               GridPane.rowIndex="2"/>
                                        <Label fx:id="onlinePlayersValueLabel" text="-" GridPane.columnIndex="1"
                                               GridPane.rowIndex="2"/>

                                        <Label styleClass="muted" text="Minecraft" GridPane.columnIndex="0"
                                               GridPane.rowIndex="3"/>
                                        <Label fx:id="minecraftVersionValueLabel" text="-" wrapText="true"
                                               GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                                        <Label styleClass="muted" text="Modpack" GridPane.columnIndex="0"
                                               GridPane.rowIndex="4"/>
                                        <Label fx:id="manifestVersionValueLabel" text="-" wrapText="true"
                                               GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                                    </children>
                                </GridPane>
                                <Label fx:id="sidebarStatusTitleLabel" styleClass="value-label" text="Проверка сервера"/>
                                <Label fx:id="sidebarStatusCopyLabel" styleClass="muted" wrapText="true"/>
                            </children>
                        </VBox>

                        <VBox spacing="10.0" styleClass="section">
                            <children>
                                <Label styleClass="section-title" text="Источники"/>
                                <GridPane hgap="12.0" vgap="8.0">
                                    <children>
                                        <Label styleClass="muted" text="Manifest URL" GridPane.columnIndex="0"
                                               GridPane.rowIndex="0"/>
                                        <Label fx:id="manifestUrlValueLabel" text="-" wrapText="true"
                                               GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                                        <Label styleClass="muted" text="Download base" GridPane.columnIndex="0"
                                               GridPane.rowIndex="1"/>
                                        <Label fx:id="downloadBaseValueLabel" text="-" wrapText="true"
                                               GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                                    </children>
                                </GridPane>
                            </children>
                        </VBox>

                        <VBox spacing="8.0" styleClass="section">
                            <children>
                                <Label styleClass="section-title" text="Журнал"/>
                                <TextArea fx:id="logArea" prefRowCount="8" wrapText="true"/>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="footer">
            <padding>
                <Insets bottom="8.0" left="14.0" right="14.0" top="8.0"/>
            </padding>
            <children>
                <Label styleClass="muted" text="Игроков онлайн:"/>
                <Label fx:id="footerOnlinePlayersValueLabel" text="-"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label styleClass="muted" text="Minecraft:"/>
                <Label fx:id="footerMinecraftVersionValueLabel" text="-"/>
                <Label styleClass="muted" text="Modpack:"/>
                <Label fx:id="footerManifestVersionValueLabel" text="-"/>
            </children>
        </HBox>
    </bottom>
</BorderPane>
