                                                    </children>
                                                </VBox>
                                                <HBox alignment="CENTER_LEFT">
                                                    <children>
                                                        <CheckBox fx:id="loginRememberCheckBox" mnemonicParsing="false" text="Remember me" styleClass="inline-check"/>
                                                        <Region HBox.hgrow="ALWAYS"/>
                                                        <Button mnemonicParsing="false" text="Forgot password?" styleClass="text-link-button"/>
                                                    </children>
                                                </HBox>
                                                <Button fx:id="loginSignInButton" mnemonicParsing="false" text="Sign In" styleClass="primary-launch-button auth-primary-button"/>
                                                <Button fx:id="loginCreateAccountButton" mnemonicParsing="false" text="Create Account" styleClass="secondary-outline-button auth-outline-button"/>
                                                <VBox alignment="CENTER" spacing="14.0" styleClass="guest-panel">
                                                    <children>
                                                        <Pane prefHeight="1.0" styleClass="card-divider"/>
                                                        <Button fx:id="loginGuestButton" mnemonicParsing="false" text="Continue as Guest" styleClass="ghost-center-button"/>
                                                        <Label text="Play offline without an account" styleClass="field-hint"/>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </StackPane>

                                <StackPane fx:id="registerView" managed="false" styleClass="screen auth-screen" visible="false">
                                    <children>
                                        <VBox maxWidth="760.0" prefWidth="760.0" spacing="20.0" styleClass="glass-card auth-card">
                                            <children>
                                                <VBox alignment="CENTER" spacing="8.0">
                                                    <children>
                                                        <Label text="Create Account" styleClass="auth-title"/>
                                                        <Label text="Join Redstone RPG Server" styleClass="screen-subtitle"/>
                                                    </children>
                                                </VBox>
                                                <VBox spacing="12.0">
                                                    <children>
                                                        <Label text="Username" styleClass="field-label"/>
                                                        <TextField fx:id="registerUsernameField" promptText="Choose a username" styleClass="launcher-input"/>
                                                    </children>
                                                </VBox>
                                                <VBox spacing="12.0">
                                                    <children>
                                                        <Label text="Email" styleClass="field-label"/>
                                                        <TextField fx:id="registerEmailField" promptText="Enter your email address" styleClass="launcher-input"/>
                                                    </children>
                                                </VBox>
                                                <VBox spacing="12.0">
                                                    <children>
                                                        <Label text="Password" styleClass="field-label"/>
                                                        <PasswordField fx:id="registerPasswordField" promptText="Create a strong password" styleClass="launcher-input"/>
                                                    </children>
                                                </VBox>
                                                <VBox spacing="12.0">
                                                    <children>
                                                        <Label text="Confirm Password" styleClass="field-label"/>
                                                        <PasswordField fx:id="registerConfirmPasswordField" promptText="Confirm your password" styleClass="launcher-input"/>
                                                    </children>
                                                </VBox>
                                                <CheckBox fx:id="registerAgreementCheckBox" mnemonicParsing="false" text="I agree to the server rules and privacy policy" styleClass="inline-check"/>
                                                <Button fx:id="registerCreateButton" mnemonicParsing="false" text="Create Account" styleClass="primary-launch-button auth-primary-button"/>
                                                <Button fx:id="registerBackButton" mnemonicParsing="false" text="Back to Sign In" styleClass="secondary-outline-button auth-outline-button"/>
                                                <Label text="Use 8+ characters with a mix of letters, numbers, and symbols to keep your account secure." styleClass="field-hint" wrapText="true"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </StackPane>

                                <ScrollPane fx:id="accountView" fitToWidth="true" hbarPolicy="NEVER" managed="false" styleClass="screen-scroll" visible="false">
                                    <content>
                                        <VBox spacing="20.0" styleClass="screen">
                                            <padding>
                                                <Insets bottom="34.0" left="44.0" right="44.0" top="48.0"/>
                                            </padding>
                                            <children>
                                                <VBox spacing="8.0">
                                                    <children>
                                                        <Label text="Account" styleClass="screen-title"/>
                                                        <Label text="Manage your profile, security and view your server stats." styleClass="screen-subtitle"/>
                                                    </children>
                                                </VBox>

                                                <HBox spacing="18.0" styleClass="glass-card content-card account-hero-card">
                                                    <children>
                                                        <StackPane minHeight="164.0" minWidth="164.0" prefHeight="164.0" prefWidth="164.0" styleClass="avatar-thumb avatar-thumb-large"/>
                                                        <VBox spacing="16.0" HBox.hgrow="ALWAYS">
                                                            <children>
                                                                <Label fx:id="accountNameLabel" styleClass="account-hero-title"/>
                                                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                                                    <children>
                                                                        <Region styleClass="presence-indicator presence-online"/>
                                                                        <Label fx:id="accountStatusLabel" styleClass="account-status-label"/>
                                                                    </children>
                                                                </HBox>
                                                                <HBox spacing="34.0">
                                                                    <children>
                                                                        <VBox spacing="14.0">
                                                                            <children>
                                                                                <HBox spacing="12.0">
                                                                                    <children>
                                                                                        <Label text="EMAIL" styleClass="metric-caption"/>
                                                                                        <Label fx:id="accountEmailLabel" styleClass="metric-value"/>
                                                                                    </children>
                                                                                </HBox>
                                                                                <HBox spacing="12.0">
                                                                                    <children>
                                                                                        <Label text="RANK" styleClass="metric-caption"/>
                                                                                        <Label fx:id="accountRankLabel" styleClass="danger-copy"/>
                                                                                    </children>
                                                                                </HBox>
                                                                            </children>
                                                                        </VBox>
                                                                        <Region HBox.hgrow="ALWAYS"/>
                                                                        <VBox spacing="14.0">
                                                                            <children>
                                                                                <HBox spacing="12.0">
                                                                                    <children>
                                                                                        <Label text="UUID" styleClass="metric-caption"/>
                                                                                        <Label text="9f3e7b2c-4a06-4d77-9b3d-8e5f1a2c9d71" styleClass="news-date"/>
                                                                                    </children>
                                                                                </HBox>
                                                                                <HBox spacing="12.0">
                                                                                    <children>
                                                                                        <Label text="JOINED" styleClass="metric-caption"/>
                                                                                        <Label text="Mar 12, 2024" styleClass="news-date"/>
                                                                                    </children>
                                                                                </HBox>
                                                                                <HBox spacing="12.0">
                                                                                    <children>
                                                                                        <Label text="LAST LOGIN" styleClass="metric-caption"/>
                                                                                        <Label text="May 18, 2025 • 2:41 PM" styleClass="news-date"/>
                                                                                    </children>
                                                                                </HBox>
                                                                                <HBox spacing="12.0">
                                                                                    <children>
                                                                                        <Label text="LINKED DISCORD" styleClass="metric-caption"/>
                                                                                        <Label text="DragonSlayer42#1337" styleClass="news-date"/>
                                                                                    </children>
                                                                                </HBox>
                                                                            </children>
                                                                        </VBox>
                                                                    </children>
                                                                </HBox>
                                                                <HBox spacing="18.0">
                                                                    <children>
                                                                        <Button fx:id="accountEditProfileButton" mnemonicParsing="false" text="Edit Profile" styleClass="secondary-rect-button" HBox.hgrow="ALWAYS"/>
                                                                        <Button fx:id="accountChangeSkinButton" mnemonicParsing="false" text="Change Skin" styleClass="outline-danger-button" HBox.hgrow="ALWAYS"/>
                                                                    </children>
                                                                </HBox>
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </HBox>

                                                <HBox spacing="18.0">
                                                    <children>
                                                        <VBox spacing="18.0" styleClass="glass-card content-card" HBox.hgrow="ALWAYS">
                                                            <children>
                                                                <Label text="Profile" styleClass="card-title"/>
                                                                <Pane prefHeight="1.0" styleClass="card-divider"/>
                                                                <HBox><children><Label text="Nickname" styleClass="field-label"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="accountProfileNicknameLabel" styleClass="metric-value"/></children></HBox>
                                                                <HBox><children><Label text="Rank" styleClass="field-label"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="accountProfileRankLabel" styleClass="danger-copy"/></children></HBox>
                                                                <HBox><children><Label text="Level" styleClass="field-label"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="accountProfileLevelLabel" styleClass="metric-value"/></children></HBox>
                                                                <HBox><children><Label text="Experience" styleClass="field-label"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="accountProfileExperienceLabel" styleClass="metric-value"/></children></HBox>
                                                                <HBox><children><Label text="Country" styleClass="field-label"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="accountProfileCountryLabel" styleClass="metric-value"/></children></HBox>
                                                                <HBox><children><Label text="Preferred Language" styleClass="field-label"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="accountProfileLanguageLabel" styleClass="metric-value"/></children></HBox>
                                                                <Button mnemonicParsing="false" text="Edit Profile" styleClass="secondary-rect-button"/>
                                                            </children>
                                                        </VBox>

                                                        <VBox spacing="18.0" styleClass="glass-card content-card" HBox.hgrow="ALWAYS">
                                                            <children>
                                                                <Label text="Security" styleClass="card-title"/>
                                                                <Pane prefHeight="1.0" styleClass="card-divider"/>
                                                                <HBox><children><Label text="Password" styleClass="field-label"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="accountSecurityPasswordLabel" styleClass="metric-value"/></children></HBox>
                                                                <HBox><children><Label text="Email" styleClass="field-label"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="accountSecurityEmailLabel" styleClass="metric-value"/></children></HBox>
                                                                <HBox><children><Label text="Two-Factor Auth" styleClass="field-label"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="accountSecurityTwoFactorLabel" styleClass="positive-copy"/></children></HBox>
                                                                <HBox><children><Label text="Backup Codes" styleClass="field-label"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="accountSecurityBackupLabel" styleClass="metric-value"/></children></HBox>
                                                                <HBox><children><Label text="Recovery Email" styleClass="field-label"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="accountSecurityRecoveryLabel" styleClass="metric-value"/></children></HBox>
                                                                <Button fx:id="accountSecurityButton" mnemonicParsing="false" text="Security Settings" styleClass="secondary-rect-button"/>
                                                            </children>
                                                        </VBox>

                                                        <VBox spacing="18.0" styleClass="glass-card content-card" HBox.hgrow="ALWAYS">
                                                            <children>
                                                                <Label text="Server Stats" styleClass="card-title"/>
                                                                <Pane prefHeight="1.0" styleClass="card-divider"/>
                                                                <HBox spacing="12.0">
                                                                    <children>
                                                                        <VBox spacing="8.0" styleClass="stat-tile" HBox.hgrow="ALWAYS">
                                                                            <children>
                                                                                <Label text="LEVEL" styleClass="metric-caption"/>
                                                                                <Label fx:id="accountStatsLevelLabel" styleClass="stat-value"/>
                                                                                <Label text="24,850 / 28,000 XP" styleClass="news-date"/>
                                                                            </children>
                                                                        </VBox>
                                                                        <VBox spacing="8.0" styleClass="stat-tile" HBox.hgrow="ALWAYS">
                                                                            <children>
                                                                                <Label text="PLAYTIME" styleClass="metric-caption"/>
                                                                                <Label fx:id="accountStatsPlaytimeLabel" styleClass="stat-value"/>
                                                                                <Label text="Total Playtime" styleClass="news-date"/>
                                                                            </children>
                                                                        </VBox>
                                                                        <VBox spacing="8.0" styleClass="stat-tile" HBox.hgrow="ALWAYS">
                                                                            <children>
                                                                                <Label text="BALANCE" styleClass="metric-caption"/>
                                                                                <Label fx:id="accountStatsBalanceLabel" styleClass="stat-value"/>
                                                                                <Label text="Redstone Coins" styleClass="news-date"/>
                                                                            </children>
                                                                        </VBox>
                                                                    </children>
                                                                </HBox>
                                                                <HBox><children><Label text="Quests Completed" styleClass="field-label"/><Region HBox.hgrow="ALWAYS"/><Label text="128" styleClass="metric-value"/></children></HBox>
                                                                <HBox><children><Label text="Bosses Defeated" styleClass="field-label"/><Region HBox.hgrow="ALWAYS"/><Label text="47" styleClass="metric-value"/></children></HBox>
                                                                <HBox><children><Label text="Vote Points" styleClass="field-label"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="accountStatsVotePointsLabel" styleClass="danger-copy"/></children></HBox>
                                                                <Button fx:id="accountMoreStatsButton" mnemonicParsing="false" text="View More Stats" styleClass="secondary-rect-button"/>
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </HBox>

                                                <Button fx:id="accountLogoutButton" mnemonicParsing="false" text="Log Out" styleClass="glass-card secondary-rect-button large-logout-button"/>
                                            </children>
                                        </VBox>
                                    </content>
                                </ScrollPane>
                            </children>
                        </StackPane>

                        <HBox alignment="CENTER_RIGHT" onMouseDragged="#dragWindow" onMousePressed="#captureWindowDrag" spacing="18.0" styleClass="window-bar" StackPane.alignment="TOP_RIGHT">
                            <children>
                                <Button fx:id="minimizeWindowButton" mnemonicParsing="false" onAction="#minimizeWindow" text="-" styleClass="window-control"/>
                                <Button fx:id="closeWindowButton" mnemonicParsing="false" onAction="#closeWindow" text="X" styleClass="window-control"/>
                            </children>
                        </HBox>

                        <VBox fx:id="logDrawerBox" managed="false" prefWidth="920.0" spacing="14.0" styleClass="glass-card content-card log-overlay" visible="false" StackPane.alignment="BOTTOM_CENTER">
                            <children>
                                <Label text="Launcher Log" styleClass="card-title"/>
                                <TextArea fx:id="logArea" prefRowCount="9" VBox.vgrow="ALWAYS"/>
                            </children>
                        </VBox>
                    </children>
                </StackPane>
            </children>
        </HBox>
    </children>
</StackPane>
