                                                                    <children>
                                                                        <Region fx:id="serverPresenceIndicator"
                                                                                styleClass="presence-indicator, presence-checking"/>
                                                                        <Label fx:id="serverPresenceLabel" text="ПРОВЕРКА"
                                                                               styleClass="presence-value"/>
                                                                    </children>
                                                                </HBox>
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </HBox>
                                                <Region styleClass="status-divider"/>
                                                <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="status-item" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <StackPane styleClass="status-icon-wrap">
                                                            <children>
                                                                <SVGPath content="M9 5 A3 3 0 1 1 9 11 A3 3 0 1 1 9 5 M3.5 19 C4.2 15.9 6.3 14.3 9 14.3 C11.7 14.3 13.8 15.9 14.5 19 M16.5 6.7 A2.3 2.3 0 1 1 16.5 11.3 A2.3 2.3 0 1 1 16.5 6.7 M14.5 14.8 C17.2 14.9 19.1 16.2 19.7 19"
                                                                         fill="TRANSPARENT" scaleX="0.84" scaleY="0.84"
                                                                         stroke="#B671FF" strokeLineCap="ROUND"
                                                                         strokeLineJoin="ROUND" strokeWidth="1.9"/>
                                                            </children>
                                                        </StackPane>
                                                        <VBox spacing="6.0">
                                                            <children>
                                                                <Label text="ИГРОКОВ ОНЛАЙН" styleClass="status-label"/>
                                                                <Label fx:id="onlinePlayersValueLabel" text="—"
                                                                       styleClass="status-value"/>
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </HBox>
                                                <Region styleClass="status-divider"/>
                                                <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="status-item" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <StackPane styleClass="status-icon-wrap">
                                                            <children>
                                                                <SVGPath content="M12 3 L20 7.5 V16.5 L12 21 L4 16.5 V7.5 Z M4.5 7.7 L12 11.9 L19.5 7.7 M12 12 V20.5"
                                                                         fill="TRANSPARENT" scaleX="0.88" scaleY="0.88"
                                                                         stroke="#A855F7" strokeLineCap="ROUND"
                                                                         strokeLineJoin="ROUND" strokeWidth="2.0"/>
                                                            </children>
                                                        </StackPane>
                                                        <VBox spacing="6.0">
                                                            <children>
                                                                <Label text="MINECRAFT" styleClass="status-label"/>
                                                                <Label fx:id="minecraftVersionValueLabel" text="—"
                                                                       styleClass="status-value" wrapText="true"/>
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </HBox>
                                                <Region styleClass="status-divider"/>
                                                <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="status-item" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <StackPane styleClass="status-icon-wrap">
                                                            <children>
                                                                <SVGPath content="M5 5 H19 V20 H5 Z M8 3 V7 M16 3 V7 M5 10 H19 M8 14 H8.01 M12 14 H12.01 M16 14 H16.01 M8 17 H8.01 M12 17 H12.01"
                                                                         fill="TRANSPARENT" scaleX="0.9" scaleY="0.9"
                                                                         stroke="#B671FF" strokeLineCap="ROUND"
                                                                         strokeLineJoin="ROUND" strokeWidth="2.0"/>
                                                            </children>
                                                        </StackPane>
                                                        <VBox spacing="6.0">
                                                            <children>
                                                                <Label text="MODPACK" styleClass="status-label"/>
                                                                <Label fx:id="manifestVersionValueLabel" text="—"
                                                                       styleClass="status-value" wrapText="true"/>
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </HBox>
                                            </children>
                                        </HBox>

                                        <HBox alignment="CENTER" spacing="18.0" styleClass="card-row">
                                            <children>
                                                <StackPane prefHeight="210.0" styleClass="info-card" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Region mouseTransparent="true" styleClass="card-art, about-art"/>
                                                        <VBox spacing="18.0" styleClass="card-content">
                                                            <children>
                                                                <HBox alignment="CENTER_LEFT" spacing="14.0">
                                                                    <children>
                                                                        <StackPane styleClass="card-icon-wrap">
                                                                            <children>
                                                                                <SVGPath content="M12 3 A9 9 0 1 1 12 21 A9 9 0 1 1 12 3 M12 10 V16 M12 7 H12.01"
                                                                                         fill="TRANSPARENT" scaleX="0.88"
                                                                                         scaleY="0.88" stroke="#C46CFF"
                                                                                         strokeLineCap="ROUND"
                                                                                         strokeLineJoin="ROUND"
                                                                                         strokeWidth="2.0"/>
                                                                            </children>
                                                                        </StackPane>
                                                                        <Label text="О сервере" styleClass="card-heading"/>
                                                                    </children>
                                                                </HBox>
                                                                <Label text="Уникальный RPG-мир, кланы, данжи и магия."
                                                                       styleClass="card-copy" wrapText="true"/>
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </StackPane>

                                                <StackPane prefHeight="210.0" styleClass="info-card" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Region mouseTransparent="true" styleClass="card-art, path-art"/>
                                                        <VBox spacing="18.0" styleClass="card-content">
                                                            <children>
                                                                <HBox alignment="CENTER_LEFT" spacing="14.0">
                                                                    <children>
                                                                        <StackPane styleClass="card-icon-wrap">
                                                                            <children>
                                                                                <SVGPath content="M14.6 5.1 L20 4 L18.9 9.4 L8.7 19.6 L4.4 15.3 Z M6.8 17.2 L3.8 20.2 M7.2 13.6 L10.4 16.8 M11.8 7.9 L16.1 12.2"
                                                                                         fill="TRANSPARENT" scaleX="0.9"
                                                                                         scaleY="0.9" stroke="#C46CFF"
                                                                                         strokeLineCap="ROUND"
                                                                                         strokeLineJoin="ROUND"
                                                                                         strokeWidth="1.9"/>
                                                                            </children>
                                                                        </StackPane>
                                                                        <Label text="Ваш путь" styleClass="card-heading"/>
                                                                    </children>
                                                                </HBox>
                                                                <Label text="Выберите класс, развивайте героя и открывайте новые земли."
                                                                       styleClass="card-copy" wrapText="true"/>
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </StackPane>

                                                <StackPane prefHeight="210.0" styleClass="info-card" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Region mouseTransparent="true" styleClass="card-art, support-art"/>
                                                        <VBox spacing="18.0" styleClass="card-content">
                                                            <children>
                                                                <HBox alignment="CENTER_LEFT" spacing="14.0">
                                                                    <children>
                                                                        <StackPane styleClass="card-icon-wrap">
                                                                            <children>
                                                                                <SVGPath content="M4 13 A8 8 0 0 1 20 13 M4 13 V17 A2 2 0 0 0 6 19 H7 V12 H6 A2 2 0 0 0 4 14 M20 13 V17 A2 2 0 0 1 18 19 H17 V12 H18 A2 2 0 0 1 20 14 M15 21 H12"
                                                                                         fill="TRANSPARENT" scaleX="0.9"
                                                                                         scaleY="0.9" stroke="#C46CFF"
                                                                                         strokeLineCap="ROUND"
                                                                                         strokeLineJoin="ROUND"
                                                                                         strokeWidth="2.0"/>
                                                                            </children>
                                                                        </StackPane>
                                                                        <Label text="Поддержка" styleClass="card-heading"/>
                                                                    </children>
                                                                </HBox>
                                                                <Label text="Discord, сайт и помощь сообщества всегда рядом."
                                                                       styleClass="card-copy" wrapText="true"/>
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </StackPane>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </children>
                        </StackPane>
                    </center>
                </BorderPane>
            </children>
        </StackPane>

        <VBox managed="false" visible="false">
            <children>
                <Label fx:id="brandLogoLabel"/>
                <Label fx:id="brandSubtitleLabel"/>
                <Label fx:id="manifestUrlValueLabel"/>
                <Label fx:id="downloadBaseValueLabel"/>
                <TextArea fx:id="logArea"/>
            </children>
        </VBox>
    </children>
</StackPane>
