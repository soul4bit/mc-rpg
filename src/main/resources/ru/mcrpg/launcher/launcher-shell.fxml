                                                                        <SVGPath content="M5 20h14v-2H5v2zM19 9h-4V3H9v6H5l7 7 7-7z"
                                                                                 fill="#F3F4F6" scaleX="0.96"
                                                                                 scaleY="0.96"/>
                                                                    </graphic>
                                                                </Button>
                                                                <Region HBox.hgrow="ALWAYS"/>
                                                                <Label fx:id="syncBytesLabel" text="Файловая активность пока отсутствует."
                                                                       styleClass="sync-bytes"/>
                                                            </children>
                                                        </HBox>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>

                                        <Region VBox.vgrow="ALWAYS"/>

                                        <HBox alignment="CENTER" spacing="0.0" styleClass="status-panel">
                                            <children>
                                                <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="status-item" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <StackPane styleClass="status-icon-wrap">
                                                            <children>
                                                                <SVGPath content="M12 3.2 L19 6 V11.3 C19 15.7 16.2 19 12 20.8 C7.8 19 5 15.7 5 11.3 V6 Z M12 8 V15 M8.8 11.3 H15.2"
                                                                         fill="TRANSPARENT" scaleX="0.88" scaleY="0.88"
                                                                         stroke="#D8C5FF" strokeLineCap="ROUND"
                                                                         strokeLineJoin="ROUND" strokeWidth="2.0"/>
                                                            </children>
                                                        </StackPane>
                                                        <VBox spacing="6.0">
                                                            <children>
                                                                <Label text="СТАТУС СЕРВЕРА" styleClass="status-label"/>
