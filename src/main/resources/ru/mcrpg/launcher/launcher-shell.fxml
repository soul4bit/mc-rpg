    <children>
        <StackPane maxWidth="Infinity" maxHeight="Infinity" styleClass="window-shell">
            <children>
                <BorderPane prefWidth="1600.0" prefHeight="900.0" styleClass="shell-frame">
                    <left>
                        <VBox prefWidth="310.0" spacing="26.0" styleClass="sidebar">
                            <padding>
                                <Insets bottom="28.0" left="22.0" right="22.0" top="28.0"/>
                            </padding>
                            <children>
                                <ImageView fitWidth="248.0" preserveRatio="true">
                                    <image>
                                        <Image url="@obsidiangate/images/logo/obsidiangate_logo_transparent_soft.png"/>
                                    </image>
                                </ImageView>

                                <VBox spacing="10.0" styleClass="nav-group">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="nav-item, nav-item-active">
                                            <children>
                                                <StackPane styleClass="nav-icon-badge, nav-icon-badge-active">
                                                    <children>
                                                        <SVGPath content="M3 11.5 L12 4 L21 11.5 M5.5 10.5 V20 H10.7 V14.4 H13.3 V20 H18.5 V10.5"
                                                                 fill="TRANSPARENT" scaleX="0.92" scaleY="0.92"
                                                                 stroke="#F4E6FF" strokeLineCap="ROUND" strokeLineJoin="ROUND"
                                                                 strokeWidth="2.2"/>
                                                    </children>
                                                </StackPane>
                                                <Label text="Главная" styleClass="nav-text, nav-text-active"/>
                                            </children>
                                        </HBox>
                                        <HBox alignment="CENTER_LEFT" onMouseClicked="#openServerScreen" spacing="16.0"
                                              styleClass="nav-item">
                                            <children>
                                                <StackPane styleClass="nav-icon-badge">
                                                    <children>
                                                        <SVGPath content="M5 5 Q5 3.5 6.5 3.5 H17.5 Q19 3.5 19 5 V19 Q19 20.5 17.5 20.5 H6.5 Q5 20.5 5 19 Z M8 8 H16 M8 12 H16 M8 16 H12"
                                                                 fill="TRANSPARENT" scaleX="0.92" scaleY="0.92"
                                                                 stroke="#9CA3AF" strokeLineCap="ROUND" strokeLineJoin="ROUND"
                                                                 strokeWidth="2.0"/>
                                                    </children>
                                                </StackPane>
                                                <Label text="Сервер" styleClass="nav-text"/>
                                            </children>
                                        </HBox>
                                        <HBox alignment="CENTER_LEFT" onMouseClicked="#openModsScreen" spacing="16.0"
                                              styleClass="nav-item">
                                            <children>
                                                <StackPane styleClass="nav-icon-badge">
                                                    <children>
                                                        <SVGPath content="M12 3 L20 7.5 V16.5 L12 21 L4 16.5 V7.5 Z M4.5 7.7 L12 11.9 L19.5 7.7 M12 12 V20.5"
                                                                 fill="TRANSPARENT" scaleX="0.9" scaleY="0.9"
                                                                 stroke="#9CA3AF" strokeLineCap="ROUND" strokeLineJoin="ROUND"
                                                                 strokeWidth="2.0"/>
                                                    </children>
                                                </StackPane>
                                                <Label text="Моды" styleClass="nav-text"/>
                                            </children>
                                        </HBox>
                                        <HBox alignment="CENTER_LEFT" onMouseClicked="#openSettingsScreen" spacing="16.0"
                                              styleClass="nav-item">
                                            <children>
                                                <StackPane styleClass="nav-icon-badge">
                                                    <children>
                                                        <Label text="⚙" styleClass="nav-glyph"/>
                                                    </children>
                                                </StackPane>
                                                <Label text="Настройки" styleClass="nav-text"/>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <Region VBox.vgrow="ALWAYS"/>

                                <VBox spacing="12.0" styleClass="sidebar-status-card">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                                            <children>
                                                <Region styleClass="system-dot"/>
                                                <Label fx:id="sidebarStatusTitleLabel" text="Проверка сервера"
                                                       styleClass="sidebar-status-title"/>
                                            </children>
                                        </HBox>
                                        <Label fx:id="sidebarStatusCopyLabel"
                                               text="Проверяем маршрут, manifest и состояние сервера."
                                               styleClass="sidebar-status-copy" wrapText="true"/>
                                        <Label fx:id="serverRouteValueLabel" styleClass="sidebar-route" wrapText="true"/>
                                    </children>
                                </VBox>

                                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="social-row">
                                    <children>
                                        <StackPane styleClass="social-chip">
                                            <children>
                                                <Label text="DS" styleClass="social-chip-label"/>
                                            </children>
                                        </StackPane>
                                        <StackPane styleClass="social-chip">
                                            <children>
                                                <Label text="VK" styleClass="social-chip-label"/>
                                            </children>
                                        </StackPane>
                                        <StackPane styleClass="social-chip">
                                            <children>
                                                <Label text="RD" styleClass="social-chip-label"/>
                                            </children>
                                        </StackPane>
                                        <StackPane styleClass="social-chip">
                                            <children>
                                                <Label text="WEB" styleClass="social-chip-label"/>
                                            </children>
                                        </StackPane>
                                    </children>
                                </HBox>

                                <Label fx:id="sidebarVersionLabel" text="Launcher" styleClass="sidebar-version"/>
                            </children>
                        </VBox>
                    </left>
                    <center>
                        <StackPane styleClass="hero-stage">
                            <children>
                                <Region styleClass="hero-background"/>
                                <Region mouseTransparent="true" styleClass="hero-overlay"/>

                                <VBox spacing="22.0" styleClass="content-column">
                                    <padding>
                                        <Insets bottom="26.0" left="28.0" right="28.0" top="14.0"/>
                                    </padding>
                                    <children>
                                        <HBox alignment="CENTER_RIGHT" onMouseDragged="#dragWindow"
                                              onMousePressed="#captureWindowDrag" spacing="12.0" styleClass="top-strip">
                                            <children>
                                                <Region HBox.hgrow="ALWAYS"/>
                                                <HBox alignment="CENTER_LEFT" onMouseClicked="#openProfileScreen"
                                                      spacing="14.0" styleClass="profile-chip">
                                                    <children>
                                                        <StackPane styleClass="avatar-shell">
                                                            <children>
                                                                <ImageView fitHeight="58.0" fitWidth="58.0"
                                                                           preserveRatio="true">
                                                                    <image>
                                                                        <Image url="@obsidiangate/images/avatar/player_avatar.png"/>
                                                                    </image>
                                                                </ImageView>
                                                            </children>
                                                        </StackPane>
                                                        <VBox spacing="4.0">
                                                            <children>
                                                                <Label fx:id="profileNameLabel" text="Arcanist_42" styleClass="profile-name"/>
                                                                <HBox alignment="CENTER_LEFT" spacing="8.0">
                                                                    <children>
                                                                        <Region styleClass="gem-mark"/>
                                                                        <Label fx:id="profileRankLabel" text="Ветеран" styleClass="profile-rank"/>
                                                                    </children>
                                                                </HBox>
                                                            </children>
                                                        </VBox>
                                                        <Label fx:id="profileChevronLabel" text="⌄" styleClass="profile-chevron"/>
                                                    </children>
                                                </HBox>
                                                <HBox alignment="CENTER_RIGHT" spacing="8.0" styleClass="window-bar">
                                                    <children>
                                                        <Button fx:id="minimizeWindowButton" mnemonicParsing="false"
                                                                onAction="#minimizeWindow"
                                                                styleClass="window-control, window-control-minimize"/>
                                                        <Button fx:id="closeWindowButton" mnemonicParsing="false"
                                                                onAction="#closeWindow"
                                                                styleClass="window-control, window-control-close"/>
                                                    </children>
                                                </HBox>
                                            </children>
                                        </HBox>

                                        <VBox alignment="CENTER" spacing="16.0" styleClass="hero-copy">
