<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ru.mcrpg.launcher.SettingsController"
            prefWidth="1360.0" prefHeight="820.0" styleClass="account-root, app-window">
    <left>
        <StackPane prefWidth="264.0" styleClass="sidebar">
            <children>
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="sidebar-scroll">
                    <content>
                        <VBox spacing="18.0" styleClass="sidebar-content">
                            <padding>
                                <Insets top="18.0" right="16.0" bottom="18.0" left="16.0"/>
                            </padding>
                            <children>
                <VBox spacing="10.0" styleClass="sidebar-brand-card">
                    <children>
                        <ImageView fitWidth="188.0" preserveRatio="true">
                            <image>
                                <Image url="@obsidiangate/images/logo/obsidiangate_logo_transparent_soft.png"/>
                            </image>
                        </ImageView>
                        <Label text="LAUNCHER CONFIG" styleClass="screen-kicker"/>
                        <Label text="Локальные параметры запуска, manifest-маршрут и Java flow редактируются отсюда."
                               wrapText="true" styleClass="label-muted"/>
                    </children>
                </VBox>

                <Label text="НАВИГАЦИЯ" styleClass="sidebar-section-label"/>

                <VBox spacing="8.0" styleClass="nav-group">
                    <children>
                        <HBox alignment="CENTER_LEFT" onMouseClicked="#onOpenHome" spacing="14.0"
                              styleClass="nav-item">
                            <children>
                                <StackPane styleClass="nav-icon-badge">
                                    <children>
                                        <SVGPath content="M3 11.5 L12 4 L21 11.5 M5.5 10.5 V20 H10.7 V14.4 H13.3 V20 H18.5 V10.5"
                                                 fill="TRANSPARENT" scaleX="0.92" scaleY="0.92"
                                                 stroke="#9CA3AF" strokeLineCap="ROUND" strokeLineJoin="ROUND"
                                                 strokeWidth="2.2"/>
                                    </children>
                                </StackPane>
                                <Label text="Главная" styleClass="nav-text"/>
                            </children>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" onMouseClicked="#onOpenServer" spacing="14.0"
                              styleClass="nav-item">
                            <children>
                                <StackPane styleClass="nav-icon-badge">
                                    <children>
                                        <SVGPath content="M5 5 Q5 3.5 6.5 3.5 H17.5 Q19 3.5 19 5 V19 Q19 20.5 17.5 20.5 H6.5 Q5 20.5 5 19 Z M8 8 H16 M8 12 H16 M8 16 H12"
                                                 fill="TRANSPARENT" scaleX="0.92" scaleY="0.92"
                                                 stroke="#9CA3AF" strokeLineCap="ROUND" strokeLineJoin="ROUND"
                                                 strokeWidth="2.0"/>
                                    </children>
                                </StackPane>
                                <Label text="Сервер" styleClass="nav-text"/>
                            </children>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" onMouseClicked="#onOpenMods" spacing="14.0"
                              styleClass="nav-item">
                            <children>
                                <StackPane styleClass="nav-icon-badge">
                                    <children>
                                        <SVGPath content="M12 3 L20 7.5 V16.5 L12 21 L4 16.5 V7.5 Z M4.5 7.7 L12 11.9 L19.5 7.7 M12 12 V20.5"
                                                 fill="TRANSPARENT" scaleX="0.9" scaleY="0.9"
                                                 stroke="#9CA3AF" strokeLineCap="ROUND" strokeLineJoin="ROUND"
                                                 strokeWidth="2.0"/>
                                    </children>
                                </StackPane>
                                <Label text="Моды" styleClass="nav-text"/>
                            </children>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" onMouseClicked="#onOpenProfile" spacing="14.0"
                              styleClass="nav-item">
                            <children>
                                <StackPane styleClass="nav-icon-badge">
                                    <children>
                                        <SVGPath content="M12 12 A4 4 0 1 1 12 4 A4 4 0 1 1 12 12 M5 20 C5.8 16.8 8.2 15 12 15 C15.8 15 18.2 16.8 19 20"
                                                 fill="TRANSPARENT" scaleX="0.88" scaleY="0.88"
                                                 stroke="#9CA3AF" strokeLineCap="ROUND" strokeLineJoin="ROUND"
                                                 strokeWidth="2.0"/>
                                    </children>
                                </StackPane>
                                <Label text="Профиль" styleClass="nav-text"/>
                            </children>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="nav-item, nav-item-active">
                            <children>
                                <StackPane styleClass="nav-icon-badge, nav-icon-badge-active">
                                    <children>
                                        <Label text="⚙" styleClass="nav-glyph, nav-glyph-active"/>
                                    </children>
                                </StackPane>
                                <Label styleClass="nav-text, nav-text-active" text="Настройки"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <VBox spacing="12.0" styleClass="sidebar-footer-card">
                    <padding>
                        <Insets top="16.0" right="16.0" bottom="16.0" left="16.0"/>
                    </padding>
                    <children>
                        <Label text="Локальный конфиг" styleClass="label-value"/>
                        <Label text="Значения сохраняются в launcher.properties и применяются следующим sync или launch."
                               wrapText="true" styleClass="label-muted"/>
                        <HBox spacing="8.0">
                            <children>
                                <VBox spacing="4.0" styleClass="sidebar-chip" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="MANIFEST" styleClass="sidebar-chip-label"/>
                                        <Label text="editable" styleClass="sidebar-chip-value"/>
                                    </children>
                                </VBox>
                                <VBox spacing="4.0" styleClass="sidebar-chip" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="JAVA" styleClass="sidebar-chip-label"/>
                                        <Label text="local" styleClass="sidebar-chip-value"/>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </StackPane>
    </left>

    <center>
        <StackPane>
            <children>
                <ImageView fitWidth="1080.0" fitHeight="820.0" preserveRatio="false" opacity="0.42">
                    <image>
                        <Image url="@obsidiangate/images/backgrounds/hero_portal_background.png"/>
                    </image>
                </ImageView>
                <Pane styleClass="profile-overlay"/>

                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="settings-scroll">
                    <content>
                        <VBox spacing="18.0" styleClass="settings-scroll-content">
                            <padding>
                                <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
                            </padding>
                            <children>
                        <HBox alignment="CENTER_RIGHT" onMouseDragged="#dragWindow" onMousePressed="#captureWindowDrag"
                              spacing="16.0">
                            <children>
                                <VBox spacing="4.0">
                                    <children>
                                        <Label text="LOCAL CONTROL" styleClass="screen-kicker"/>
                                        <Label text="Настройки launcher" styleClass="auth-title"/>
                                        <Label text="Сервер, manifest, локальные пути и launch template редактируются прямо из UI."
                                               styleClass="label-muted" wrapText="true"/>
                                    </children>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button fx:id="minimizeWindowButton" mnemonicParsing="false"
                                        onAction="#minimizeWindow" styleClass="window-control"/>
                                <Button fx:id="closeWindowButton" mnemonicParsing="false"
                                        onAction="#closeWindow" styleClass="window-control, window-control-close"/>
                            </children>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="profile-hero-card">
                            <children>
                                <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Локальная конфигурация" styleClass="profile-main-name"/>
                                        <Label text="Изменения сохраняются в launcher.properties и используются следующими sync и launch."
                                               styleClass="label-body" wrapText="true"/>
                                        <Label fx:id="statusLabel" styleClass="label-muted, settings-status-success" wrapText="true"/>
                                    </children>
                                </VBox>
                                <VBox alignment="CENTER_RIGHT" spacing="12.0" styleClass="action-stack">
                                    <children>
                                        <Button minWidth="220.0" mnemonicParsing="false" onAction="#onSaveSettings"
                                                styleClass="primary-button" text="Сохранить настройки"/>
                                        <Button minWidth="220.0" mnemonicParsing="false" onAction="#onReloadSaved"
                                                styleClass="secondary-button" text="Вернуть сохраненное"/>
                                        <Button minWidth="220.0" mnemonicParsing="false" onAction="#onResetDefaults"
                                                styleClass="secondary-button" text="Загрузить defaults"/>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <FlowPane hgap="18.0" vgap="18.0" prefWrapLength="980.0">
                            <children>
                                <VBox prefWidth="200.0" spacing="6.0" styleClass="metric-card, metric-card-compact">
                                    <children>
                                        <Label text="SERVER ROUTE" styleClass="label-muted"/>
                                        <Label fx:id="routeSummaryValueLabel" styleClass="metric-value-small" wrapText="true"/>
                                    </children>
                                </VBox>
                                <VBox prefWidth="250.0" spacing="6.0" styleClass="metric-card, metric-card-compact">
                                    <children>
                                        <Label text="MANIFEST URL" styleClass="label-muted"/>
                                        <Label fx:id="manifestSummaryValueLabel" styleClass="metric-value-small" wrapText="true"/>
                                    </children>
                                </VBox>
                                <VBox prefWidth="230.0" spacing="6.0" styleClass="metric-card, metric-card-compact">
                                    <children>
                                        <Label text="AUTH BASE URL" styleClass="label-muted"/>
                                        <Label fx:id="authSummaryValueLabel" styleClass="metric-value-small" wrapText="true"/>
                                    </children>
                                </VBox>
                                <VBox spacing="6.0" styleClass="metric-card, metric-card-compact" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="CONFIG FILE" styleClass="label-muted"/>
                                        <Label fx:id="configPathValueLabel" styleClass="metric-value-small" wrapText="true"/>
                                    </children>
                                </VBox>
                            </children>
                        </FlowPane>

                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="settings-scroll" VBox.vgrow="ALWAYS">
                            <content>
                                <VBox spacing="20.0" styleClass="settings-scroll-content">
                                    <children>
                                        <FlowPane hgap="20.0" vgap="20.0" prefWrapLength="980.0">
                                            <children>
                                                <VBox prefWidth="470.0" spacing="18.0" styleClass="profile-card">
                                                    <children>
                                                        <Label text="Подключение и сервер" styleClass="label-value"/>
                                                        <Label text="Эти поля определяют загрузку manifest, auth API и точку подключения к Minecraft-серверу."
                                                               styleClass="label-muted" wrapText="true"/>

                                                        <VBox spacing="8.0" styleClass="settings-field-stack">
                                                            <children>
                                                                <Label text="Manifest URL" styleClass="field-label"/>
                                                                <TextField fx:id="manifestUrlField" promptText="http://host:8080/manifest.json"
                                                                           styleClass="auth-field"/>
                                                            </children>
                                                        </VBox>

                                                        <VBox spacing="8.0" styleClass="settings-field-stack">
                                                            <children>
                                                                <Label text="Auth Base URL" styleClass="field-label"/>
                                                                <TextField fx:id="authBaseUrlField" promptText="http://host:8081"
                                                                           styleClass="auth-field"/>
                                                            </children>
                                                        </VBox>

                                                        <HBox spacing="14.0">
                                                            <children>
                                                                <VBox spacing="8.0" styleClass="settings-field-stack" HBox.hgrow="ALWAYS">
                                                                    <children>
                                                                        <Label text="Server Host" styleClass="field-label"/>
                                                                        <TextField fx:id="serverHostField" promptText="obsidiangates.duckdns.org"
                                                                                   styleClass="auth-field"/>
                                                                    </children>
                                                                </VBox>
                                                                <VBox prefWidth="150.0" spacing="8.0" styleClass="settings-field-stack">
                                                                    <children>
                                                                        <Label text="Server Port" styleClass="field-label"/>
                                                                        <TextField fx:id="serverPortField" promptText="25565"
                                                                                   styleClass="auth-field"/>
                                                                    </children>
                                                                </VBox>
                                                            </children>
                                                        </HBox>

                                                        <VBox spacing="8.0" styleClass="settings-field-stack">
                                                            <children>
                                                                <Label text="Server ID" styleClass="field-label"/>
                                                                <TextField fx:id="serverIdField" promptText="obsidiangate-main"
                                                                           styleClass="auth-field"/>
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </VBox>

                                                <VBox prefWidth="470.0" spacing="18.0" styleClass="profile-card">
                                                    <children>
                                                        <Label text="Локальный клиент" styleClass="label-value"/>
                                                        <Label text="Ниже находятся пути, Java-команда и режим обновления перед запуском."
                                                               styleClass="label-muted" wrapText="true"/>

                                                        <VBox spacing="8.0" styleClass="settings-field-stack">
                                                            <children>
                                                                <Label text="Game Directory" styleClass="field-label"/>
                                                                <TextField fx:id="gameDirectoryField" promptText="C:\Games\rpg-client"
                                                                           styleClass="auth-field"/>
                                                            </children>
                                                        </VBox>

                                                        <VBox spacing="8.0" styleClass="settings-field-stack">
                                                            <children>
                                                                <Label text="Working Directory" styleClass="field-label"/>
                                                                <TextField fx:id="workingDirectoryField" promptText="Пусто = game directory"
                                                                           styleClass="auth-field"/>
                                                            </children>
                                                        </VBox>

                                                        <VBox spacing="8.0" styleClass="settings-field-stack">
                                                            <children>
                                                                <Label text="Java Command" styleClass="field-label"/>
                                                                <TextField fx:id="javaCommandField" promptText="java"
                                                                           styleClass="auth-field"/>
                                                            </children>
                                                        </VBox>

                                                        <CheckBox fx:id="updateFilesBeforeLaunchCheckBox"
                                                                  mnemonicParsing="false"
                                                                  styleClass="check-box"
                                                                  text="Синхронизировать файлы перед launch"/>

                                                        <Label text="Если sync перед launch отключен, launcher попробует стартовать клиент с уже существующими локальными файлами."
                                                               styleClass="label-muted" wrapText="true"/>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </FlowPane>

                                        <VBox spacing="16.0" styleClass="profile-card">
                                            <children>
                                                <Label text="Шаблон запуска" styleClass="label-value"/>
                                                <Label text="Поддерживаются placeholders {java}, {username}, {gameDir}, {workingDir}, {serverHost}, {serverPort}, {uuid}, {accessToken}, {gameSessionFile}."
                                                       styleClass="label-muted" wrapText="true"/>
                                                <TextArea fx:id="launchTemplateArea" prefRowCount="5"
                                                          styleClass="auth-field, settings-template-area"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                            </content>
                        </ScrollPane>
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </StackPane>
    </center>
</BorderPane>
