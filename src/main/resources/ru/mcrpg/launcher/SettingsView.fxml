<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ru.mcrpg.launcher.SettingsController"
            prefHeight="820.0" prefWidth="1360.0" styleClass="account-root, app-window">
    <left>
        <StackPane prefWidth="264.0" styleClass="sidebar">
            <children>
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="sidebar-scroll">
                    <content>
                        <VBox spacing="18.0" styleClass="sidebar-content">
                            <padding>
                                <Insets bottom="18.0" left="16.0" right="16.0" top="18.0"/>
                            </padding>
                            <children>
                                <VBox spacing="10.0" styleClass="sidebar-brand-card">
                                    <children>
                                        <ImageView fitWidth="188.0" preserveRatio="true">
                                            <image>
                                                <Image url="@obsidiangate/images/logo/obsidiangate_logo_transparent_soft.png"/>
                                            </image>
                                        </ImageView>
                                        <Label text="НАСТРОЙКИ LAUNCHER" styleClass="screen-kicker"/>
                                        <Label text="Здесь редактируются локальные адреса, пути, Java-команда и шаблон запуска."
                                               styleClass="label-muted" wrapText="true"/>
                                    </children>
                                </VBox>

                                <Label text="РАЗДЕЛЫ" styleClass="sidebar-section-label"/>

                                <VBox spacing="8.0" styleClass="nav-group">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" onMouseClicked="#onOpenHome" spacing="14.0"
                                              styleClass="nav-item">
                                            <children>
                                                <StackPane styleClass="nav-icon-badge">
                                                    <children>
                                                        <SVGPath content="M3 11.5 L12 4 L21 11.5 M5.5 10.5 V20 H10.7 V14.4 H13.3 V20 H18.5 V10.5"
                                                                 fill="TRANSPARENT" scaleX="0.92" scaleY="0.92"
                                                                 stroke="#9CA3AF" strokeLineCap="ROUND" strokeLineJoin="ROUND"
                                                                 strokeWidth="2.2"/>
                                                    </children>
                                                </StackPane>
                                                <Label styleClass="nav-text" text="Главная"/>
                                            </children>
                                        </HBox>
                                        <HBox alignment="CENTER_LEFT" onMouseClicked="#onOpenServer" spacing="14.0"
                                              styleClass="nav-item">
                                            <children>
                                                <StackPane styleClass="nav-icon-badge">
                                                    <children>
                                                        <SVGPath content="M5 5 Q5 3.5 6.5 3.5 H17.5 Q19 3.5 19 5 V19 Q19 20.5 17.5 20.5 H6.5 Q5 20.5 5 19 Z M8 8 H16 M8 12 H16 M8 16 H12"
                                                                 fill="TRANSPARENT" scaleX="0.92" scaleY="0.92"
                                                                 stroke="#9CA3AF" strokeLineCap="ROUND" strokeLineJoin="ROUND"
                                                                 strokeWidth="2.0"/>
                                                    </children>
                                                </StackPane>
                                                <Label styleClass="nav-text" text="Сервер"/>
                                            </children>
                                        </HBox>
                                        <HBox alignment="CENTER_LEFT" onMouseClicked="#onOpenMods" spacing="14.0"
                                              styleClass="nav-item">
                                            <children>
                                                <StackPane styleClass="nav-icon-badge">
                                                    <children>
                                                        <SVGPath content="M12 3 L20 7.5 V16.5 L12 21 L4 16.5 V7.5 Z M4.5 7.7 L12 11.9 L19.5 7.7 M12 12 V20.5"
                                                                 fill="TRANSPARENT" scaleX="0.9" scaleY="0.9"
                                                                 stroke="#9CA3AF" strokeLineCap="ROUND" strokeLineJoin="ROUND"
                                                                 strokeWidth="2.0"/>
                                                    </children>
                                                </StackPane>
                                                <Label styleClass="nav-text" text="Моды"/>
                                            </children>
                                        </HBox>
                                        <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="nav-item, nav-item-active">
                                            <children>
                                                <StackPane styleClass="nav-icon-badge, nav-icon-badge-active">
                                                    <children>
                                                        <Label styleClass="nav-glyph, nav-glyph-active" text="⚙"/>
                                                    </children>
                                                </StackPane>
                                                <Label styleClass="nav-text, nav-text-active" text="Настройки"/>
                                            </children>
                                        </HBox>
                                        <HBox alignment="CENTER_LEFT" onMouseClicked="#onOpenProfile" spacing="14.0"
                                              styleClass="nav-item">
                                            <children>
                                                <StackPane styleClass="nav-icon-badge">
                                                    <children>
                                                        <SVGPath content="M12 12 A4 4 0 1 1 12 4 A4 4 0 1 1 12 12 M5 20 C5.8 16.8 8.2 15 12 15 C15.8 15 18.2 16.8 19 20"
                                                                 fill="TRANSPARENT" scaleX="0.88" scaleY="0.88"
                                                                 stroke="#9CA3AF" strokeLineCap="ROUND" strokeLineJoin="ROUND"
                                                                 strokeWidth="2.0"/>
                                                    </children>
                                                </StackPane>
                                                <Label styleClass="nav-text" text="Профиль"/>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <VBox spacing="12.0" styleClass="sidebar-footer-card">
                                    <padding>
                                        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0"/>
                                    </padding>
                                    <children>
                                        <Label text="Что меняется отсюда" styleClass="label-value"/>
                                        <Label text="Эти значения влияют на manifest, auth API, рабочую папку клиента и итоговую команду запуска."
                                               styleClass="label-muted" wrapText="true"/>
                                        <HBox spacing="8.0">
                                            <children>
                                                <VBox spacing="4.0" styleClass="sidebar-chip" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label text="MANIFEST" styleClass="sidebar-chip-label"/>
                                                        <Label text="адрес" styleClass="sidebar-chip-value"/>
                                                    </children>
                                                </VBox>
                                                <VBox spacing="4.0" styleClass="sidebar-chip" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label text="JAVA" styleClass="sidebar-chip-label"/>
                                                        <Label text="команда" styleClass="sidebar-chip-value"/>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </StackPane>
    </left>

    <center>
        <StackPane>
            <children>
                <ImageView fitHeight="820.0" fitWidth="1080.0" opacity="0.42" preserveRatio="false">
                    <image>
                        <Image url="@obsidiangate/images/backgrounds/hero_portal_background.png"/>
                    </image>
                </ImageView>
                <Pane styleClass="page-overlay"/>

                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="settings-scroll">
                    <content>
                        <VBox spacing="18.0" styleClass="settings-scroll-content">
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
                            </padding>
                            <children>
                                <HBox alignment="CENTER_RIGHT" onMouseDragged="#dragWindow" onMousePressed="#captureWindowDrag"
                                      spacing="16.0" styleClass="page-toolbar">
                                    <children>
                                        <VBox spacing="4.0">
                                            <children>
                                                <Label text="ЛОКАЛЬНАЯ КОНФИГУРАЦИЯ" styleClass="screen-kicker"/>
                                                <Label text="Настройки запуска" styleClass="auth-title"/>
                                                <Label text="Сверху быстрые действия и краткая сводка, ниже подробные поля для подключения и запуска клиента."
                                                       styleClass="label-muted" wrapText="true"/>
                                            </children>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Button fx:id="minimizeWindowButton" mnemonicParsing="false"
                                                onAction="#minimizeWindow" styleClass="window-control"/>
                                        <Button fx:id="closeWindowButton" mnemonicParsing="false"
                                                onAction="#closeWindow" styleClass="window-control, window-control-close"/>
                                    </children>
                                </HBox>

                                <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="profile-hero-card">
                                    <children>
                                        <VBox spacing="12.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Локальная конфигурация launcher" styleClass="profile-main-name"/>
                                                <Label text="Любые изменения применятся к следующим операциям sync и launch после сохранения."
                                                       styleClass="label-body" wrapText="true"/>
                                                <Label fx:id="statusLabel" styleClass="label-muted, settings-status-success" wrapText="true"/>
                                            </children>
                                        </VBox>
                                        <VBox alignment="CENTER_RIGHT" spacing="12.0" styleClass="action-stack">
                                            <children>
                                                <Button minWidth="220.0" mnemonicParsing="false" onAction="#onSaveSettings"
                                                        styleClass="primary-button" text="Сохранить изменения"/>
                                                <Button minWidth="220.0" mnemonicParsing="false" onAction="#onReloadSaved"
                                                        styleClass="secondary-button" text="Вернуть сохранённое"/>
                                                <Button minWidth="220.0" mnemonicParsing="false" onAction="#onResetDefaults"
                                                        styleClass="secondary-button" text="Загрузить defaults"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <FlowPane hgap="18.0" prefWrapLength="980.0" vgap="18.0">
                                    <children>
                                        <VBox prefWidth="200.0" spacing="6.0" styleClass="metric-card, metric-card-compact">
                                            <children>
                                                <Label text="МАРШРУТ СЕРВЕРА" styleClass="label-muted"/>
                                                <Label fx:id="routeSummaryValueLabel" styleClass="metric-value-small" wrapText="true"/>
                                            </children>
                                        </VBox>
                                        <VBox prefWidth="240.0" spacing="6.0" styleClass="metric-card, metric-card-compact">
                                            <children>
                                                <Label text="АДРЕС MANIFEST" styleClass="label-muted"/>
                                                <Label fx:id="manifestSummaryValueLabel" styleClass="metric-value-small" wrapText="true"/>
                                            </children>
                                        </VBox>
                                        <VBox prefWidth="220.0" spacing="6.0" styleClass="metric-card, metric-card-compact">
                                            <children>
                                                <Label text="АДРЕС AUTH API" styleClass="label-muted"/>
                                                <Label fx:id="authSummaryValueLabel" styleClass="metric-value-small" wrapText="true"/>
                                            </children>
                                        </VBox>
                                        <VBox spacing="6.0" styleClass="metric-card, metric-card-compact" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="ФАЙЛ КОНФИГА" styleClass="label-muted"/>
                                                <Label fx:id="configPathValueLabel" styleClass="metric-value-small" wrapText="true"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </FlowPane>

                                <FlowPane hgap="20.0" prefWrapLength="980.0" vgap="20.0">
                                    <children>
                                        <VBox prefWidth="470.0" spacing="18.0" styleClass="profile-card">
                                            <children>
                                                <Label text="Подключение и сервер" styleClass="label-value"/>
                                                <Label text="Эти параметры определяют, где лаунчер ищет manifest, auth API и к какому серверу будет подключаться игра."
                                                       styleClass="label-body" wrapText="true"/>

                                                <VBox spacing="8.0" styleClass="settings-field-stack">
                                                    <children>
                                                        <Label text="Адрес manifest" styleClass="field-label"/>
                                                        <TextField fx:id="manifestUrlField" promptText="http://host:8080/manifest.json"
                                                                   styleClass="auth-field"/>
                                                        <Label text="Используется для чтения версии modpack, списка файлов и возможных overrides."
                                                               styleClass="field-note" wrapText="true"/>
                                                    </children>
                                                </VBox>

                                                <VBox spacing="8.0" styleClass="settings-field-stack">
                                                    <children>
                                                        <Label text="Auth Base URL" styleClass="field-label"/>
                                                        <TextField fx:id="authBaseUrlField" promptText="http://host:8081"
                                                                   styleClass="auth-field"/>
                                                        <Label text="Адрес backend API для входа, профиля и выдачи игровых ticket."
                                                               styleClass="field-note" wrapText="true"/>
                                                    </children>
                                                </VBox>

                                                <HBox spacing="14.0">
                                                    <children>
                                                        <VBox spacing="8.0" styleClass="settings-field-stack" HBox.hgrow="ALWAYS">
                                                            <children>
                                                                <Label text="Хост сервера" styleClass="field-label"/>
                                                                <TextField fx:id="serverHostField" promptText="obsidiangates.duckdns.org"
                                                                           styleClass="auth-field"/>
                                                            </children>
                                                        </VBox>
                                                        <VBox prefWidth="150.0" spacing="8.0" styleClass="settings-field-stack">
                                                            <children>
                                                                <Label text="Порт сервера" styleClass="field-label"/>
                                                                <TextField fx:id="serverPortField" promptText="25565"
                                                                           styleClass="auth-field"/>
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </HBox>

                                                <VBox spacing="8.0" styleClass="settings-field-stack">
                                                    <children>
                                                        <Label text="Идентификатор сервера" styleClass="field-label"/>
                                                        <TextField fx:id="serverIdField" promptText="obsidiangate-main"
                                                                   styleClass="auth-field"/>
                                                        <Label text="Идентификатор полезен для ticket flow и серверной логики."
                                                               styleClass="field-note" wrapText="true"/>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>

                                        <VBox prefWidth="470.0" spacing="18.0" styleClass="profile-card">
                                            <children>
                                                <Label text="Локальный клиент" styleClass="label-value"/>
                                                <Label text="Ниже находятся пути и Java-команда, которые используются непосредственно перед запуском игры."
                                                       styleClass="label-body" wrapText="true"/>

                                                <VBox spacing="8.0" styleClass="settings-field-stack">
                                                    <children>
                                                        <Label text="Папка игры" styleClass="field-label"/>
                                                        <TextField fx:id="gameDirectoryField" promptText="C:\Games\rpg-client"
                                                                   styleClass="auth-field"/>
                                                        <Label text="Основная папка клиента. Здесь находятся modpack, конфиги и локальные файлы игры."
                                                               styleClass="field-note" wrapText="true"/>
                                                    </children>
                                                </VBox>

                                                <VBox spacing="8.0" styleClass="settings-field-stack">
                                                    <children>
                                                        <Label text="Рабочая папка" styleClass="field-label"/>
                                                        <TextField fx:id="workingDirectoryField" promptText="Пусто = game directory"
                                                                   styleClass="auth-field"/>
                                                        <Label text="Если поле пустое, будет использована папка игры."
                                                               styleClass="field-note" wrapText="true"/>
                                                    </children>
                                                </VBox>

                                                <VBox spacing="8.0" styleClass="settings-field-stack">
                                                    <children>
                                                        <Label text="Команда Java" styleClass="field-label"/>
                                                        <TextField fx:id="javaCommandField" promptText="java"
                                                                   styleClass="auth-field"/>
                                                        <Label text="Команда или путь к Java, которые launcher подставит в шаблон запуска."
                                                               styleClass="field-note" wrapText="true"/>
                                                    </children>
                                                </VBox>

                                                <CheckBox fx:id="updateFilesBeforeLaunchCheckBox"
                                                          mnemonicParsing="false" styleClass="check-box"
                                                          text="Синхронизировать файлы перед запуском"/>

                                                <Label text="Если отключить синхронизацию, launcher попробует стартовать игру с уже существующими локальными файлами."
                                                       styleClass="field-note" wrapText="true"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </FlowPane>

                                <VBox spacing="16.0" styleClass="profile-card">
                                    <children>
                                        <Label text="Шаблон запуска" styleClass="label-value"/>
                                        <Label text="Поддерживаются placeholders {java}, {username}, {gameDir}, {workingDir}, {serverHost}, {serverPort}, {uuid}, {accessToken}, {gameSessionFile}."
                                               styleClass="label-body" wrapText="true"/>
                                        <TextArea fx:id="launchTemplateArea" prefRowCount="5"
                                                  styleClass="auth-field, settings-template-area"/>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </StackPane>
    </center>
</BorderPane>
