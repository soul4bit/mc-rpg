<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ru.mcrpg.launcher.SettingsController"
            prefWidth="1600.0" prefHeight="900.0" styleClass="account-root, app-window">
    <left>
        <VBox prefWidth="310.0" spacing="28.0" styleClass="sidebar">
            <padding>
                <Insets top="42.0" right="24.0" bottom="28.0" left="24.0"/>
            </padding>
            <children>
                <ImageView fitWidth="230.0" preserveRatio="true">
                    <image>
                        <Image url="@obsidiangate/images/logo/obsidiangate_logo_transparent_soft.png"/>
                    </image>
                </ImageView>
                <VBox spacing="14.0">
                    <children>
                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onOpenHome"
                                styleClass="nav-button" text="Главная"/>
                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onOpenProfile"
                                styleClass="nav-button" text="Профиль"/>
                        <Label styleClass="nav-button, nav-button-active" text="Настройки"/>
                    </children>
                </VBox>
                <Region VBox.vgrow="ALWAYS"/>
                <VBox spacing="10.0" styleClass="glass-panel">
                    <padding>
                        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
                    </padding>
                    <children>
                        <Label text="Конфиг лаунчера" styleClass="label-value"/>
                        <Label text="Здесь меняются локальные параметры запуска. Значения из manifest все еще могут переопределить server host, port, working directory и launch template."
                               wrapText="true" styleClass="label-muted"/>
                    </children>
                </VBox>
            </children>
        </VBox>
    </left>

    <center>
        <StackPane>
            <children>
                <ImageView fitWidth="1290.0" fitHeight="900.0" preserveRatio="false" opacity="0.42">
                    <image>
                        <Image url="@obsidiangate/images/backgrounds/hero_portal_background.png"/>
                    </image>
                </ImageView>
                <Pane styleClass="profile-overlay"/>

                <VBox spacing="20.0">
                    <padding>
                        <Insets top="26.0" right="42.0" bottom="42.0" left="42.0"/>
                    </padding>
                    <children>
                        <HBox alignment="CENTER_RIGHT" onMouseDragged="#dragWindow" onMousePressed="#captureWindowDrag"
                              spacing="16.0">
                            <children>
                                <VBox spacing="4.0">
                                    <children>
                                        <Label text="Настройки лаунчера" styleClass="auth-title"/>
                                        <Label text="Сервер, manifest, локальные пути и шаблон запуска теперь редактируются прямо из UI."
                                               styleClass="label-muted" wrapText="true"/>
                                    </children>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button fx:id="minimizeWindowButton" mnemonicParsing="false"
                                        onAction="#minimizeWindow" styleClass="window-control"/>
                                <Button fx:id="closeWindowButton" mnemonicParsing="false"
                                        onAction="#closeWindow" styleClass="window-control, window-control-close"/>
                            </children>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="22.0" styleClass="profile-hero-card">
                            <children>
                                <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Локальная конфигурация" styleClass="profile-main-name"/>
                                        <Label text="Изменения сохраняются в launcher.properties и будут использованы следующим sync/launch. Если значение оставить пустым, лаунчер подставит default."
                                               styleClass="label-body" wrapText="true"/>
                                        <Label fx:id="statusLabel" styleClass="label-muted, settings-status-success" wrapText="true"/>
                                    </children>
                                </VBox>
                                <VBox alignment="CENTER_RIGHT" spacing="12.0">
                                    <children>
                                        <Button minWidth="250.0" mnemonicParsing="false" onAction="#onSaveSettings"
                                                styleClass="primary-button" text="СОХРАНИТЬ НАСТРОЙКИ"/>
                                        <Button minWidth="250.0" mnemonicParsing="false" onAction="#onReloadSaved"
                                                styleClass="secondary-button" text="ВЕРНУТЬ СОХРАНЕННОЕ"/>
                                        <Button minWidth="250.0" mnemonicParsing="false" onAction="#onResetDefaults"
                                                styleClass="secondary-button" text="ЗАГРУЗИТЬ DEFAULTS"/>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox spacing="18.0">
                            <children>
                                <VBox prefWidth="220.0" spacing="6.0" styleClass="metric-card">
                                    <children>
                                        <Label text="SERVER ROUTE" styleClass="label-muted"/>
                                        <Label fx:id="routeSummaryValueLabel" styleClass="metric-value-small" wrapText="true"/>
                                    </children>
                                </VBox>
                                <VBox prefWidth="300.0" spacing="6.0" styleClass="metric-card">
                                    <children>
                                        <Label text="MANIFEST URL" styleClass="label-muted"/>
                                        <Label fx:id="manifestSummaryValueLabel" styleClass="metric-value-small" wrapText="true"/>
                                    </children>
                                </VBox>
                                <VBox prefWidth="270.0" spacing="6.0" styleClass="metric-card">
                                    <children>
                                        <Label text="AUTH BASE URL" styleClass="label-muted"/>
                                        <Label fx:id="authSummaryValueLabel" styleClass="metric-value-small" wrapText="true"/>
                                    </children>
                                </VBox>
                                <VBox spacing="6.0" styleClass="metric-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="CONFIG FILE" styleClass="label-muted"/>
                                        <Label fx:id="configPathValueLabel" styleClass="metric-value-small" wrapText="true"/>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="settings-scroll" VBox.vgrow="ALWAYS">
                            <content>
                                <VBox spacing="20.0" styleClass="settings-scroll-content">
                                    <children>
                                        <HBox spacing="20.0">
                                            <children>
                                                <VBox prefWidth="560.0" spacing="18.0" styleClass="profile-card" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label text="Подключение и сервер" styleClass="label-value"/>
                                                        <Label text="Эти значения управляют загрузкой manifest, auth API и точкой подключения к Minecraft серверу."
                                                               styleClass="label-muted" wrapText="true"/>

                                                        <VBox spacing="8.0" styleClass="settings-field-stack">
                                                            <children>
                                                                <Label text="Manifest URL" styleClass="field-label"/>
                                                                <TextField fx:id="manifestUrlField" promptText="http://host:8080/manifest.json"
                                                                           styleClass="auth-field"/>
                                                            </children>
                                                        </VBox>

                                                        <VBox spacing="8.0" styleClass="settings-field-stack">
                                                            <children>
                                                                <Label text="Auth Base URL" styleClass="field-label"/>
                                                                <TextField fx:id="authBaseUrlField" promptText="http://host:8081"
                                                                           styleClass="auth-field"/>
                                                            </children>
                                                        </VBox>

                                                        <HBox spacing="14.0">
                                                            <children>
                                                                <VBox spacing="8.0" styleClass="settings-field-stack" HBox.hgrow="ALWAYS">
                                                                    <children>
                                                                        <Label text="Server Host" styleClass="field-label"/>
                                                                        <TextField fx:id="serverHostField" promptText="obsidiangates.duckdns.org"
                                                                                   styleClass="auth-field"/>
                                                                    </children>
                                                                </VBox>
                                                                <VBox prefWidth="150.0" spacing="8.0" styleClass="settings-field-stack">
                                                                    <children>
                                                                        <Label text="Server Port" styleClass="field-label"/>
                                                                        <TextField fx:id="serverPortField" promptText="25565"
                                                                                   styleClass="auth-field"/>
                                                                    </children>
                                                                </VBox>
                                                            </children>
                                                        </HBox>

                                                        <VBox spacing="8.0" styleClass="settings-field-stack">
                                                            <children>
                                                                <Label text="Server ID" styleClass="field-label"/>
                                                                <TextField fx:id="serverIdField" promptText="obsidiangate-main"
                                                                           styleClass="auth-field"/>
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </VBox>

                                                <VBox prefWidth="560.0" spacing="18.0" styleClass="profile-card" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label text="Локальный клиент" styleClass="label-value"/>
                                                        <Label text="Настройки ниже управляют локальным Java-процессом и расположением файлов на машине игрока."
                                                               styleClass="label-muted" wrapText="true"/>

                                                        <VBox spacing="8.0" styleClass="settings-field-stack">
                                                            <children>
                                                                <Label text="Game Directory" styleClass="field-label"/>
                                                                <TextField fx:id="gameDirectoryField" promptText="C:\Games\rpg-client"
                                                                           styleClass="auth-field"/>
                                                            </children>
                                                        </VBox>

                                                        <VBox spacing="8.0" styleClass="settings-field-stack">
                                                            <children>
                                                                <Label text="Working Directory" styleClass="field-label"/>
                                                                <TextField fx:id="workingDirectoryField" promptText="Пусто = game directory"
                                                                           styleClass="auth-field"/>
                                                            </children>
                                                        </VBox>

                                                        <VBox spacing="8.0" styleClass="settings-field-stack">
                                                            <children>
                                                                <Label text="Java Command" styleClass="field-label"/>
                                                                <TextField fx:id="javaCommandField" promptText="java"
                                                                           styleClass="auth-field"/>
                                                            </children>
                                                        </VBox>

                                                        <CheckBox fx:id="updateFilesBeforeLaunchCheckBox"
                                                                  mnemonicParsing="false"
                                                                  styleClass="check-box"
                                                                  text="Синхронизировать файлы перед launch"/>

                                                        <Label text="Если sync перед launch выключен, лаунчер попробует стартовать клиент с уже существующими локальными файлами."
                                                               styleClass="label-muted" wrapText="true"/>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>

                                        <VBox spacing="16.0" styleClass="profile-card">
                                            <children>
                                                <Label text="Шаблон запуска" styleClass="label-value"/>
                                                <Label text="Поддерживаются плейсхолдеры {java}, {username}, {gameDir}, {workingDir}, {serverHost}, {serverPort}, {uuid}, {accessToken}, {gameSessionFile}."
                                                       styleClass="label-muted" wrapText="true"/>
                                                <TextArea fx:id="launchTemplateArea" prefRowCount="5"
                                                          styleClass="auth-field, settings-template-area"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                            </content>
                        </ScrollPane>
                    </children>
                </VBox>
            </children>
        </StackPane>
    </center>
</BorderPane>
