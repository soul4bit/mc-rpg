<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="ru.mcrpg.launcher.AuthController" styleClass="account-root">
    <children>
        <ImageView fitWidth="1600.0" fitHeight="900.0" preserveRatio="false" opacity="0.70">
            <image>
                <Image url="@obsidiangate/images/backgrounds/hero_portal_background.png"/>
            </image>
        </ImageView>
        <Pane styleClass="auth-background-overlay"/>

        <BorderPane prefWidth="1600.0" prefHeight="900.0" styleClass="app-window">
            <top>
                <HBox alignment="CENTER_RIGHT" onMouseDragged="#dragWindow" onMousePressed="#captureWindowDrag"
                      spacing="12.0" styleClass="account-window-bar">
                    <padding>
                        <Insets top="24.0" right="30.0" bottom="0.0" left="30.0"/>
                    </padding>
                    <children>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="minimizeWindowButton" mnemonicParsing="false"
                                onAction="#minimizeWindow" styleClass="window-control"/>
                        <Button fx:id="closeWindowButton" mnemonicParsing="false"
                                onAction="#closeWindow" styleClass="window-control, window-control-close"/>
                    </children>
                </HBox>
            </top>

            <center>
                <HBox alignment="CENTER" spacing="56.0">
                    <padding>
                        <Insets top="10.0" right="82.0" bottom="60.0" left="82.0"/>
                    </padding>
                    <children>
                        <VBox maxWidth="500.0" prefWidth="500.0" spacing="22.0" styleClass="auth-card">
                            <children>
                                <ImageView fitWidth="210.0" preserveRatio="true">
                                    <image>
                                        <Image url="@obsidiangate/images/logo/obsidiangate_logo_transparent_soft.png"/>
                                    </image>
                                </ImageView>
                                <VBox spacing="8.0">
                                    <children>
                                        <Label text="Вход в аккаунт" styleClass="auth-title"/>
                                        <Label text="Войди в профиль, чтобы запустить RPG-сервер и продолжить приключение."
                                               wrapText="true" styleClass="auth-subtitle"/>
                                    </children>
                                </VBox>

                                <VBox spacing="14.0">
                                    <children>
                                        <VBox spacing="7.0">
                                            <children>
                                                <Label text="Логин или email" styleClass="field-label"/>
                                                <TextField fx:id="loginField" promptText="Например: Arcanist_42"
                                                           styleClass="auth-field"/>
                                            </children>
                                        </VBox>
                                        <VBox spacing="7.0">
                                            <children>
                                                <Label text="Пароль" styleClass="field-label"/>
                                                <PasswordField fx:id="passwordField" promptText="Введите пароль"
                                                               styleClass="auth-field"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>

                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <CheckBox fx:id="rememberCheck" text="Запомнить меня"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Hyperlink fx:id="forgotPasswordLink" text="Забыли пароль?"
                                                   styleClass="link-button"/>
                                    </children>
                                </HBox>

                                <Label fx:id="statusLabel" styleClass="status-error" wrapText="true"/>

                                <Button fx:id="loginButton" maxWidth="Infinity" mnemonicParsing="false"
                                        onAction="#onLogin" styleClass="primary-button"
                                        text="ВОЙТИ В ЛАУНЧЕР"/>

                                <Region styleClass="divider"/>

                                <HBox alignment="CENTER" spacing="8.0">
                                    <children>
                                        <Label text="Нет аккаунта?" styleClass="label-muted"/>
                                        <Hyperlink fx:id="openRegisterLink" text="Создать аккаунт"
                                                   onAction="#openRegister" styleClass="link-button"/>
                                    </children>
                                </HBox>

                                <Button fx:id="offlineButton" maxWidth="Infinity" mnemonicParsing="false"
                                        onAction="#onOffline" styleClass="secondary-button"
                                        text="ИГРАТЬ ОФФЛАЙН"/>
                            </children>
                        </VBox>

                        <VBox maxWidth="560.0" prefWidth="560.0" spacing="24.0" styleClass="auth-side-card">
                            <children>
                                <Label text="OBSIDIANGATE" styleClass="title-main"/>
                                <Label text="Тёмный RPG-мир, магия, кланы, данжи и путь героя — всё в одном лаунчере."
                                       wrapText="true" styleClass="label-body"/>
                                <VBox spacing="14.0">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="14.0">
                                            <children>
                                                <Label text="◆" styleClass="label-purple-accent"/>
                                                <Label text="Единый аккаунт для лаунчера и сайта" styleClass="label-value"/>
                                            </children>
                                        </HBox>
                                        <HBox alignment="CENTER_LEFT" spacing="14.0">
                                            <children>
                                                <Label text="◆" styleClass="label-purple-accent"/>
                                                <Label text="Быстрый запуск сервера и автопроверка модов" styleClass="label-value"/>
                                            </children>
                                        </HBox>
                                        <HBox alignment="CENTER_LEFT" spacing="14.0">
                                            <children>
                                                <Label text="◆" styleClass="label-purple-accent"/>
                                                <Label text="Личный кабинет, статистика и безопасность" styleClass="label-value"/>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </center>
        </BorderPane>
    </children>
</StackPane>
