<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ru.mcrpg.launcher.AuthController"
            prefHeight="720.0" prefWidth="1040.0" styleClass="account-root">
    <top>
        <HBox alignment="CENTER_LEFT" onMouseDragged="#dragWindow" onMousePressed="#captureWindowDrag"
              spacing="10.0" styleClass="top-bar">
            <padding>
                <Insets bottom="10.0" left="14.0" right="10.0" top="10.0"/>
            </padding>
            <children>
                <Label styleClass="app-title" text="ObsidianGate"/>
                <Label styleClass="muted" text="Вход"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button mnemonicParsing="false" onAction="#minimizeWindow" styleClass="window-button" text="_"/>
                <Button mnemonicParsing="false" onAction="#closeWindow" styleClass="window-button" text="X"/>
            </children>
        </HBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="12.0">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0"/>
            </padding>
            <children>
                <VBox maxWidth="440.0" spacing="12.0" styleClass="section">
                    <children>
                        <Label styleClass="page-title" text="Вход в аккаунт"/>
                        <Label styleClass="muted" text="Введите логин и пароль лаунчера." wrapText="true"/>

                        <VBox spacing="5.0">
                            <children>
                                <Label styleClass="field-label" text="Логин"/>
                                <TextField fx:id="loginField" promptText="Имя игрока"/>
                            </children>
                        </VBox>

                        <VBox spacing="5.0">
                            <children>
                                <Label styleClass="field-label" text="Пароль"/>
                                <PasswordField fx:id="passwordField" promptText="Пароль"/>
                            </children>
                        </VBox>

                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <CheckBox fx:id="rememberCheck" text="Запомнить вход"/>
                            </children>
                        </HBox>

                        <Label fx:id="statusLabel" styleClass="status-error" wrapText="true"/>
                        <Button fx:id="loginButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                                onAction="#onLogin" styleClass="primary-button" text="Войти"/>

                        <HBox alignment="CENTER" spacing="6.0">
                            <children>
                                <Label styleClass="muted" text="Нет аккаунта?"/>
                                <Hyperlink fx:id="openRegisterLink" onAction="#openRegister" text="Зарегистрироваться"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>
</BorderPane>
