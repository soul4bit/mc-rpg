<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ru.mcrpg.launcher.ModsController"
            prefWidth="1600.0" prefHeight="900.0" styleClass="account-root, app-window">
    <left>
        <VBox prefWidth="310.0" spacing="28.0" styleClass="sidebar">
            <padding>
                <Insets top="42.0" right="24.0" bottom="28.0" left="24.0"/>
            </padding>
            <children>
                <ImageView fitWidth="230.0" preserveRatio="true">
                    <image>
                        <Image url="@obsidiangate/images/logo/obsidiangate_logo_transparent_soft.png"/>
                    </image>
                </ImageView>
                <VBox spacing="14.0">
                    <children>
                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onOpenHome"
                                styleClass="nav-button" text="Главная"/>
                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onOpenProfile"
                                styleClass="nav-button" text="Профиль"/>
                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onOpenServer"
                                styleClass="nav-button" text="Сервер"/>
                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onOpenSettings"
                                styleClass="nav-button" text="Настройки"/>
                        <Label styleClass="nav-button, nav-button-active" text="Моды"/>
                    </children>
                </VBox>
                <Region VBox.vgrow="ALWAYS"/>
                <VBox spacing="10.0" styleClass="glass-panel">
                    <padding>
                        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
                    </padding>
                    <children>
                        <Label text="Manifest inventory" styleClass="label-value"/>
                        <Label text="Экран показывает фактический список `manifest.files[]` и runtime packages, которые клиент должен скачать или переиспользовать."
                               wrapText="true" styleClass="label-muted"/>
                    </children>
                </VBox>
            </children>
        </VBox>
    </left>

    <center>
        <StackPane>
            <children>
                <ImageView fitWidth="1290.0" fitHeight="900.0" preserveRatio="false" opacity="0.42">
                    <image>
                        <Image url="@obsidiangate/images/backgrounds/hero_portal_background.png"/>
                    </image>
                </ImageView>
                <Pane styleClass="profile-overlay"/>

                <VBox spacing="22.0">
                    <padding>
                        <Insets top="26.0" right="42.0" bottom="42.0" left="42.0"/>
                    </padding>
                    <children>
                        <HBox alignment="CENTER_RIGHT" onMouseDragged="#dragWindow" onMousePressed="#captureWindowDrag"
                              spacing="16.0">
                            <children>
                                <VBox spacing="4.0">
                                    <children>
                                        <Label text="Моды и файлы modpack" styleClass="auth-title"/>
                                        <Label text="Реальный inventory из manifest: версии, sha256, размеры и runtime packages."
                                               styleClass="label-muted" wrapText="true"/>
                                    </children>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button fx:id="minimizeWindowButton" mnemonicParsing="false"
                                        onAction="#minimizeWindow" styleClass="window-control"/>
                                <Button fx:id="closeWindowButton" mnemonicParsing="false"
                                        onAction="#closeWindow" styleClass="window-control, window-control-close"/>
                            </children>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="22.0" styleClass="profile-hero-card">
                            <children>
                                <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Manifest inventory" styleClass="profile-main-name"/>
                                        <Label fx:id="statusLabel" styleClass="label-body" wrapText="true"/>
                                    </children>
                                </VBox>
                                <VBox alignment="CENTER_RIGHT" spacing="12.0">
                                    <children>
                                        <Button minWidth="220.0" mnemonicParsing="false" onAction="#onRefreshManifest"
                                                styleClass="primary-button" text="ОБНОВИТЬ MANIFEST"/>
                                        <Label text="Перечитывает manifest и rebuild списка файлов." styleClass="label-muted"/>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox spacing="18.0">
                            <children>
                                <VBox prefWidth="220.0" spacing="6.0" styleClass="metric-card">
                                    <children>
                                        <Label text="MANIFEST VERSION" styleClass="label-muted"/>
                                        <Label fx:id="manifestVersionValueLabel" styleClass="metric-value-small" wrapText="true"/>
                                    </children>
                                </VBox>
                                <VBox prefWidth="180.0" spacing="6.0" styleClass="metric-card">
                                    <children>
                                        <Label text="FILES" styleClass="label-muted"/>
                                        <Label fx:id="filesCountValueLabel" styleClass="metric-value"/>
                                    </children>
                                </VBox>
                                <VBox prefWidth="180.0" spacing="6.0" styleClass="metric-card">
                                    <children>
                                        <Label text="MOD JARS" styleClass="label-muted"/>
                                        <Label fx:id="modsCountValueLabel" styleClass="metric-value"/>
                                    </children>
                                </VBox>
                                <VBox prefWidth="180.0" spacing="6.0" styleClass="metric-card">
                                    <children>
                                        <Label text="RUNTIME" styleClass="label-muted"/>
                                        <Label fx:id="runtimeCountValueLabel" styleClass="metric-value"/>
                                    </children>
                                </VBox>
                                <VBox spacing="6.0" styleClass="metric-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="TOTAL SIZE" styleClass="label-muted"/>
                                        <Label fx:id="totalSizeValueLabel" styleClass="metric-value"/>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox spacing="18.0">
                            <children>
                                <VBox prefWidth="520.0" spacing="6.0" styleClass="metric-card">
                                    <children>
                                        <Label text="MANIFEST URL" styleClass="label-muted"/>
                                        <Label fx:id="manifestUrlValueLabel" styleClass="metric-value-small" wrapText="true"/>
                                    </children>
                                </VBox>
                                <VBox spacing="6.0" styleClass="metric-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="RESOLVED DOWNLOAD BASE" styleClass="label-muted"/>
                                        <Label fx:id="downloadBaseValueLabel" styleClass="metric-value-small" wrapText="true"/>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox spacing="20.0" VBox.vgrow="ALWAYS">
                            <children>
                                <VBox prefWidth="370.0" spacing="16.0" styleClass="profile-card">
                                    <children>
                                        <Label text="Runtime packages" styleClass="label-value"/>
                                        <Label text="Portable Java и другие platform-specific пакеты, объявленные в manifest.runtime.packages."
                                               wrapText="true" styleClass="label-muted"/>
                                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="settings-scroll" VBox.vgrow="ALWAYS">
                                            <content>
                                                <VBox fx:id="runtimePackagesBox" spacing="12.0" styleClass="settings-scroll-content"/>
                                            </content>
                                        </ScrollPane>
                                    </children>
                                </VBox>

                                <VBox spacing="16.0" styleClass="profile-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="manifest.files[]" styleClass="label-value"/>
                                        <Label text="Фактический список клиентских файлов с path, размером, sha256 и категорией."
                                               wrapText="true" styleClass="label-muted"/>
                                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="settings-scroll" VBox.vgrow="ALWAYS">
                                            <content>
                                                <VBox fx:id="manifestFilesBox" spacing="12.0" styleClass="settings-scroll-content"/>
                                            </content>
                                        </ScrollPane>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </StackPane>
    </center>
</BorderPane>
