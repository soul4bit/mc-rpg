<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ru.mcrpg.launcher.ProfileController"
            prefHeight="780.0" prefWidth="1180.0" styleClass="account-root">
    <top>
        <HBox alignment="CENTER_LEFT" onMouseDragged="#dragWindow" onMousePressed="#captureWindowDrag"
              spacing="10.0" styleClass="top-bar">
            <padding>
                <Insets bottom="10.0" left="14.0" right="10.0" top="10.0"/>
            </padding>
            <children>
                <Label styleClass="app-title" text="ObsidianGate"/>
                <Label styleClass="muted" text="Профиль"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button mnemonicParsing="false" onAction="#minimizeWindow" styleClass="window-button" text="_"/>
                <Button mnemonicParsing="false" onAction="#closeWindow" styleClass="window-button" text="X"/>
            </children>
        </HBox>
    </top>

    <left>
        <VBox prefWidth="220.0" spacing="8.0" styleClass="sidebar">
            <padding>
                <Insets bottom="14.0" left="14.0" right="14.0" top="14.0"/>
            </padding>
            <children>
                <Label styleClass="section-title" text="Навигация"/>
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onOpenHome" text="Главная"/>
                <Button disable="true" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Профиль"/>
                <Region VBox.vgrow="ALWAYS"/>
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onLogout"
                        text="Выйти из аккаунта"/>
            </children>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="content-scroll">
            <content>
                <VBox spacing="14.0" styleClass="content">
                    <padding>
                        <Insets bottom="18.0" left="18.0" right="18.0" top="18.0"/>
                    </padding>
                    <children>
                        <VBox spacing="8.0" styleClass="section">
                            <children>
                                <Label styleClass="page-title" text="Профиль игрока"/>
                                <Label fx:id="statusLabel" styleClass="muted" wrapText="true"/>
                            </children>
                        </VBox>

                        <VBox spacing="10.0" styleClass="section">
                            <children>
                                <Label styleClass="section-title" text="Аккаунт"/>
                                <GridPane hgap="12.0" vgap="8.0">
                                    <children>
                                        <Label styleClass="muted" text="Ник" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                        <Label fx:id="profileNameLabel" styleClass="value-label" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                        <Label styleClass="muted" text="Роль" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                        <Label fx:id="profileRoleLabel" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                                        <Label styleClass="muted" text="Email" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                        <Label fx:id="profileEmailLabel" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                                        <Label styleClass="muted" text="ID аккаунта" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                                        <Label fx:id="accountIdLabel" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                                    </children>
                                </GridPane>
                            </children>
                        </VBox>

                        <VBox spacing="10.0" styleClass="section">
                            <children>
                                <Label styleClass="section-title" text="Лаунчер"/>
                                <GridPane hgap="12.0" vgap="8.0">
                                    <children>
                                        <Label styleClass="muted" text="Server ID" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                        <Label fx:id="launcherServerIdLabel" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                        <Label styleClass="muted" text="Папка игры" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                        <Label fx:id="launcherPathLabel" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                                    </children>
                                </GridPane>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
