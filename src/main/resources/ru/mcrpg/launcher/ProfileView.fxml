<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ru.mcrpg.launcher.ProfileController"
            prefWidth="1360.0" prefHeight="820.0" styleClass="account-root, app-window">
    <left>
        <StackPane prefWidth="264.0" styleClass="sidebar">
            <children>
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="sidebar-scroll">
                    <content>
                        <VBox spacing="18.0" styleClass="sidebar-content">
                            <padding>
                                <Insets top="18.0" right="16.0" bottom="18.0" left="16.0"/>
                            </padding>
                            <children>
                <VBox spacing="10.0" styleClass="sidebar-brand-card">
                    <children>
                        <ImageView fitWidth="188.0" preserveRatio="true">
                            <image>
                                <Image url="@obsidiangate/images/logo/obsidiangate_logo_transparent_soft.png"/>
                            </image>
                        </ImageView>
                        <Label text="ACCOUNT HUB" styleClass="screen-kicker"/>
                        <Label text="Профиль игрока, маршрут запуска и состояние сессии собраны в одном экране."
                               wrapText="true" styleClass="label-muted"/>
                    </children>
                </VBox>

                <Label text="НАВИГАЦИЯ" styleClass="sidebar-section-label"/>

                <VBox spacing="8.0" styleClass="nav-group">
                    <children>
                        <HBox alignment="CENTER_LEFT" onMouseClicked="#onOpenHome" spacing="14.0"
                              styleClass="nav-item">
                            <children>
                                <StackPane styleClass="nav-icon-badge">
                                    <children>
                                        <SVGPath content="M3 11.5 L12 4 L21 11.5 M5.5 10.5 V20 H10.7 V14.4 H13.3 V20 H18.5 V10.5"
                                                 fill="TRANSPARENT" scaleX="0.92" scaleY="0.92"
                                                 stroke="#9CA3AF" strokeLineCap="ROUND" strokeLineJoin="ROUND"
                                                 strokeWidth="2.2"/>
                                    </children>
                                </StackPane>
                                <Label text="Главная" styleClass="nav-text"/>
                            </children>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" onMouseClicked="#onOpenServer" spacing="14.0"
                              styleClass="nav-item">
                            <children>
                                <StackPane styleClass="nav-icon-badge">
                                    <children>
                                        <SVGPath content="M5 5 Q5 3.5 6.5 3.5 H17.5 Q19 3.5 19 5 V19 Q19 20.5 17.5 20.5 H6.5 Q5 20.5 5 19 Z M8 8 H16 M8 12 H16 M8 16 H12"
                                                 fill="TRANSPARENT" scaleX="0.92" scaleY="0.92"
                                                 stroke="#9CA3AF" strokeLineCap="ROUND" strokeLineJoin="ROUND"
                                                 strokeWidth="2.0"/>
                                    </children>
                                </StackPane>
                                <Label text="Сервер" styleClass="nav-text"/>
                            </children>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" onMouseClicked="#onOpenMods" spacing="14.0"
                              styleClass="nav-item">
                            <children>
                                <StackPane styleClass="nav-icon-badge">
                                    <children>
                                        <SVGPath content="M12 3 L20 7.5 V16.5 L12 21 L4 16.5 V7.5 Z M4.5 7.7 L12 11.9 L19.5 7.7 M12 12 V20.5"
                                                 fill="TRANSPARENT" scaleX="0.9" scaleY="0.9"
                                                 stroke="#9CA3AF" strokeLineCap="ROUND" strokeLineJoin="ROUND"
                                                 strokeWidth="2.0"/>
                                    </children>
                                </StackPane>
                                <Label text="Моды" styleClass="nav-text"/>
                            </children>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" onMouseClicked="#onOpenSettings" spacing="14.0"
                              styleClass="nav-item">
                            <children>
                                <StackPane styleClass="nav-icon-badge">
                                    <children>
                                        <Label text="⚙" styleClass="nav-glyph"/>
                                    </children>
                                </StackPane>
                                <Label text="Настройки" styleClass="nav-text"/>
                            </children>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="nav-item, nav-item-active">
                            <children>
                                <StackPane styleClass="nav-icon-badge, nav-icon-badge-active">
                                    <children>
                                        <SVGPath content="M12 12 A4 4 0 1 1 12 4 A4 4 0 1 1 12 12 M5 20 C5.8 16.8 8.2 15 12 15 C15.8 15 18.2 16.8 19 20"
                                                 fill="TRANSPARENT" scaleX="0.88" scaleY="0.88"
                                                 stroke="#F4E6FF" strokeLineCap="ROUND" strokeLineJoin="ROUND"
                                                 strokeWidth="2.0"/>
                                    </children>
                                </StackPane>
                                <Label styleClass="nav-text, nav-text-active" text="Профиль"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <VBox spacing="12.0" styleClass="sidebar-footer-card">
                    <padding>
                        <Insets top="16.0" right="16.0" bottom="16.0" left="16.0"/>
                    </padding>
                    <children>
                        <Label text="Аккаунт защищен" styleClass="label-value"/>
                        <Label text="Текущая сессия привязана к launcher auth и backend API."
                               wrapText="true" styleClass="label-muted"/>
                        <HBox spacing="8.0">
                            <children>
                                <VBox spacing="4.0" styleClass="sidebar-chip" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="AUTH" styleClass="sidebar-chip-label"/>
                                        <Label text="backend" styleClass="sidebar-chip-value"/>
                                    </children>
                                </VBox>
                                <VBox spacing="4.0" styleClass="sidebar-chip" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="STATE" styleClass="sidebar-chip-label"/>
                                        <Label text="live" styleClass="sidebar-chip-value"/>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onLogout"
                        styleClass="secondary-button" text="Выйти"/>
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </StackPane>
    </left>

    <center>
        <StackPane>
            <children>
                <ImageView fitWidth="1080.0" fitHeight="820.0" preserveRatio="false" opacity="0.42">
                    <image>
                        <Image url="@obsidiangate/images/backgrounds/hero_portal_background.png"/>
                    </image>
                </ImageView>
                <Pane styleClass="profile-overlay"/>

                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="settings-scroll">
                    <content>
                        <VBox spacing="18.0" styleClass="settings-scroll-content">
                            <padding>
                                <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
                            </padding>
                            <children>
                        <HBox alignment="CENTER_RIGHT" onMouseDragged="#dragWindow" onMousePressed="#captureWindowDrag"
                              spacing="16.0">
                            <children>
                                <VBox spacing="4.0">
                                    <children>
                                        <Label text="PLAYER IDENTITY" styleClass="screen-kicker"/>
                                        <Label text="Личный кабинет" styleClass="auth-title"/>
                                        <Label text="Профиль, безопасность и игровые данные в одном маршруте."
                                               styleClass="label-muted"/>
                                    </children>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button fx:id="minimizeWindowButton" mnemonicParsing="false"
                                        onAction="#minimizeWindow" styleClass="window-control"/>
                                <Button fx:id="closeWindowButton" mnemonicParsing="false"
                                        onAction="#closeWindow" styleClass="window-control, window-control-close"/>
                            </children>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="profile-hero-card">
                            <children>
                                <StackPane styleClass="avatar-frame">
                                    <children>
                                        <ImageView fitWidth="96.0" fitHeight="96.0">
                                            <image>
                                                <Image url="@obsidiangate/images/avatar/player_avatar.png"/>
                                            </image>
                                        </ImageView>
                                    </children>
                                </StackPane>
                                <VBox spacing="10.0">
                                    <children>
                                        <Label fx:id="profileNameLabel" styleClass="profile-main-name"/>
                                        <Label fx:id="profileRoleLabel" styleClass="label-purple"/>
                                        <Label fx:id="profileEmailLabel" styleClass="label-body"/>
                                        <Label fx:id="statusLabel" styleClass="label-muted" wrapText="true"/>
                                    </children>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS"/>
                                <VBox alignment="CENTER_RIGHT" spacing="12.0" styleClass="action-stack">
                                    <children>
                                        <Button mnemonicParsing="false" onAction="#onChangeSkin"
                                                styleClass="primary-button" text="Сменить скин"/>
                                        <Button mnemonicParsing="false" onAction="#onEditProfile"
                                                styleClass="secondary-button" text="Изменить профиль"/>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <FlowPane hgap="18.0" vgap="18.0" prefWrapLength="980.0">
                            <children>
                                <VBox prefWidth="210.0" spacing="6.0" styleClass="metric-card, metric-card-compact">
                                    <children>
                                        <Label text="ACCOUNT ID" styleClass="label-muted"/>
                                        <Label fx:id="accountIdLabel" styleClass="metric-value-small" wrapText="true"/>
                                    </children>
                                </VBox>
                                <VBox prefWidth="210.0" spacing="6.0" styleClass="metric-card, metric-card-compact">
                                    <children>
                                        <Label text="AUTH" styleClass="label-muted"/>
                                        <Label text="launcher-auth" styleClass="metric-value"/>
                                        <Label text="через backend API" styleClass="label-purple"/>
                                    </children>
                                </VBox>
                                <VBox prefWidth="210.0" spacing="6.0" styleClass="metric-card, metric-card-compact">
                                    <children>
                                        <Label text="SERVER ID" styleClass="label-muted"/>
                                        <Label fx:id="launcherServerIdLabel" styleClass="metric-value-small" wrapText="true"/>
                                    </children>
                                </VBox>
                                <VBox prefWidth="210.0" spacing="6.0" styleClass="metric-card, metric-card-compact">
                                    <children>
                                        <Label text="GAME DIR" styleClass="label-muted"/>
                                        <Label fx:id="launcherPathLabel" styleClass="metric-value-small" wrapText="true"/>
                                    </children>
                                </VBox>
                            </children>
                        </FlowPane>

                        <FlowPane hgap="20.0" vgap="20.0" prefWrapLength="980.0" VBox.vgrow="ALWAYS">
                            <children>
                                <VBox prefWidth="320.0" spacing="16.0" styleClass="profile-card">
                                    <children>
                                        <Label text="Безопасность" styleClass="label-value"/>
                                        <Label text="Email привязан к backend-аккаунту и участвует в auth flow."
                                               styleClass="label-body" wrapText="true"/>
                                        <Label text="Следующий этап: смена пароля и подключение 2FA." styleClass="label-muted"/>
                                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onEnableTwoFactor"
                                                styleClass="secondary-button" text="Включить 2FA"/>
                                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onChangePassword"
                                                styleClass="secondary-button" text="Сменить пароль"/>
                                    </children>
                                </VBox>

                                <VBox prefWidth="320.0" spacing="16.0" styleClass="profile-card">
                                    <children>
                                        <Label text="Персонаж" styleClass="label-value"/>
                                        <Label text="Серверные метрики и RPG-статистика появятся здесь после полной интеграции backend и Forge-мода."
                                               wrapText="true" styleClass="label-body"/>
                                        <Label text="Сейчас экран готов под будущие игровые данные и персональный прогресс."
                                               wrapText="true" styleClass="label-muted"/>
                                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onOpenStats"
                                                styleClass="secondary-button" text="Открыть статистику"/>
                                    </children>
                                </VBox>

                                <VBox prefWidth="320.0" spacing="16.0" styleClass="profile-card">
                                    <children>
                                        <Label text="Launcher flow" styleClass="label-value"/>
                                        <Label text="Перед стартом клиента launcher получает одноразовый game ticket и пробрасывает его в игру."
                                               wrapText="true" styleClass="label-body"/>
                                        <Label text="Отсюда удобно перейти к настройкам маршрута, manifest и путей запуска."
                                               wrapText="true" styleClass="label-muted"/>
                                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onLauncherSettings"
                                                styleClass="secondary-button" text="Открыть настройки"/>
                                    </children>
                                </VBox>
                            </children>
                        </FlowPane>
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </StackPane>
    </center>
</BorderPane>
