<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ru.mcrpg.launcher.ProfileController"
            prefHeight="820.0" prefWidth="1360.0" styleClass="account-root, app-window">
    <left>
        <StackPane prefWidth="264.0" styleClass="sidebar">
            <children>
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="sidebar-scroll">
                    <content>
                        <VBox spacing="18.0" styleClass="sidebar-content">
                            <padding>
                                <Insets bottom="18.0" left="16.0" right="16.0" top="18.0"/>
                            </padding>
                            <children>
                                <VBox spacing="10.0" styleClass="sidebar-brand-card">
                                    <children>
                                        <ImageView fitWidth="188.0" preserveRatio="true">
                                            <image>
                                                <Image url="@obsidiangate/images/logo/obsidiangate_logo_transparent_soft.png"/>
                                            </image>
                                        </ImageView>
                                        <Label text="ЛИЧНЫЙ КАБИНЕТ" styleClass="screen-kicker"/>
                                        <Label text="Здесь собраны данные аккаунта, безопасность и быстрые переходы к настройкам запуска."
                                               styleClass="label-muted" wrapText="true"/>
                                    </children>
                                </VBox>

                                <Label text="РАЗДЕЛЫ" styleClass="sidebar-section-label"/>

                                <VBox spacing="8.0" styleClass="nav-group">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" onMouseClicked="#onOpenHome" spacing="14.0"
                                              styleClass="nav-item">
                                            <children>
                                                <StackPane styleClass="nav-icon-badge">
                                                    <children>
                                                        <SVGPath content="M3 11.5 L12 4 L21 11.5 M5.5 10.5 V20 H10.7 V14.4 H13.3 V20 H18.5 V10.5"
                                                                 fill="TRANSPARENT" scaleX="0.92" scaleY="0.92"
                                                                 stroke="#9CA3AF" strokeLineCap="ROUND" strokeLineJoin="ROUND"
                                                                 strokeWidth="2.2"/>
                                                    </children>
                                                </StackPane>
                                                <Label styleClass="nav-text" text="Главная"/>
                                            </children>
                                        </HBox>
                                        <HBox alignment="CENTER_LEFT" onMouseClicked="#onOpenServer" spacing="14.0"
                                              styleClass="nav-item">
                                            <children>
                                                <StackPane styleClass="nav-icon-badge">
                                                    <children>
                                                        <SVGPath content="M5 5 Q5 3.5 6.5 3.5 H17.5 Q19 3.5 19 5 V19 Q19 20.5 17.5 20.5 H6.5 Q5 20.5 5 19 Z M8 8 H16 M8 12 H16 M8 16 H12"
                                                                 fill="TRANSPARENT" scaleX="0.92" scaleY="0.92"
                                                                 stroke="#9CA3AF" strokeLineCap="ROUND" strokeLineJoin="ROUND"
                                                                 strokeWidth="2.0"/>
                                                    </children>
                                                </StackPane>
                                                <Label styleClass="nav-text" text="Сервер"/>
                                            </children>
                                        </HBox>
                                        <HBox alignment="CENTER_LEFT" onMouseClicked="#onOpenMods" spacing="14.0"
                                              styleClass="nav-item">
                                            <children>
                                                <StackPane styleClass="nav-icon-badge">
                                                    <children>
                                                        <SVGPath content="M12 3 L20 7.5 V16.5 L12 21 L4 16.5 V7.5 Z M4.5 7.7 L12 11.9 L19.5 7.7 M12 12 V20.5"
                                                                 fill="TRANSPARENT" scaleX="0.9" scaleY="0.9"
                                                                 stroke="#9CA3AF" strokeLineCap="ROUND" strokeLineJoin="ROUND"
                                                                 strokeWidth="2.0"/>
                                                    </children>
                                                </StackPane>
                                                <Label styleClass="nav-text" text="Моды"/>
                                            </children>
                                        </HBox>
                                        <HBox alignment="CENTER_LEFT" onMouseClicked="#onOpenSettings" spacing="14.0"
                                              styleClass="nav-item">
                                            <children>
                                                <StackPane styleClass="nav-icon-badge">
                                                    <children>
                                                        <Label styleClass="nav-glyph" text="⚙"/>
                                                    </children>
                                                </StackPane>
                                                <Label styleClass="nav-text" text="Настройки"/>
                                            </children>
                                        </HBox>
                                        <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="nav-item, nav-item-active">
                                            <children>
                                                <StackPane styleClass="nav-icon-badge, nav-icon-badge-active">
                                                    <children>
                                                        <SVGPath content="M12 12 A4 4 0 1 1 12 4 A4 4 0 1 1 12 12 M5 20 C5.8 16.8 8.2 15 12 15 C15.8 15 18.2 16.8 19 20"
                                                                 fill="TRANSPARENT" scaleX="0.88" scaleY="0.88"
                                                                 stroke="#F4E6FF" strokeLineCap="ROUND" strokeLineJoin="ROUND"
                                                                 strokeWidth="2.0"/>
                                                    </children>
                                                </StackPane>
                                                <Label styleClass="nav-text, nav-text-active" text="Профиль"/>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <VBox spacing="12.0" styleClass="sidebar-footer-card">
                                    <padding>
                                        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0"/>
                                    </padding>
                                    <children>
                                        <Label text="Текущая сессия" styleClass="label-value"/>
                                        <Label text="Если доступ истечёт, лаунчер вернёт на экран входа и попросит авторизоваться заново."
                                               styleClass="label-muted" wrapText="true"/>
                                        <HBox spacing="8.0">
                                            <children>
                                                <VBox spacing="4.0" styleClass="sidebar-chip" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label text="ВХОД" styleClass="sidebar-chip-label"/>
                                                        <Label text="активен" styleClass="sidebar-chip-value"/>
                                                    </children>
                                                </VBox>
                                                <VBox spacing="4.0" styleClass="sidebar-chip" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label text="SYNC" styleClass="sidebar-chip-label"/>
                                                        <Label text="доступен" styleClass="sidebar-chip-value"/>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onLogout"
                                        styleClass="secondary-button" text="Выйти из аккаунта"/>
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </StackPane>
    </left>

    <center>
        <StackPane>
            <children>
                <ImageView fitHeight="820.0" fitWidth="1080.0" opacity="0.42" preserveRatio="false">
                    <image>
                        <Image url="@obsidiangate/images/backgrounds/hero_portal_background.png"/>
                    </image>
                </ImageView>
                <Pane styleClass="page-overlay"/>

                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="settings-scroll">
                    <content>
                        <VBox spacing="18.0" styleClass="settings-scroll-content">
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
                            </padding>
                            <children>
                                <HBox alignment="CENTER_RIGHT" onMouseDragged="#dragWindow" onMousePressed="#captureWindowDrag"
                                      spacing="16.0" styleClass="page-toolbar">
                                    <children>
                                        <VBox spacing="4.0">
                                            <children>
                                                <Label text="АККАУНТ И БЕЗОПАСНОСТЬ" styleClass="screen-kicker"/>
                                                <Label text="Профиль игрока" styleClass="auth-title"/>
                                                <Label text="Основные данные аккаунта и быстрые действия собраны на одном экране."
                                                       styleClass="label-muted" wrapText="true"/>
                                            </children>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Button fx:id="minimizeWindowButton" mnemonicParsing="false"
                                                onAction="#minimizeWindow" styleClass="window-control"/>
                                        <Button fx:id="closeWindowButton" mnemonicParsing="false"
                                                onAction="#closeWindow" styleClass="window-control, window-control-close"/>
                                    </children>
                                </HBox>

                                <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="profile-hero-card">
                                    <children>
                                        <StackPane styleClass="avatar-frame">
                                            <children>
                                                <ImageView fitHeight="96.0" fitWidth="96.0">
                                                    <image>
                                                        <Image url="@obsidiangate/images/avatar/player_avatar.png"/>
                                                    </image>
                                                </ImageView>
                                            </children>
                                        </StackPane>
                                        <VBox spacing="10.0">
                                            <children>
                                                <Label fx:id="profileNameLabel" styleClass="profile-main-name"/>
                                                <Label fx:id="profileRoleLabel" styleClass="label-purple-accent"/>
                                                <Label fx:id="profileEmailLabel" styleClass="label-body" wrapText="true"/>
                                                <Label fx:id="statusLabel" styleClass="label-muted" wrapText="true"/>
                                            </children>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <VBox alignment="CENTER_RIGHT" spacing="12.0" styleClass="action-stack">
                                            <children>
                                                <Button mnemonicParsing="false" onAction="#onEditProfile"
                                                        styleClass="primary-button" text="Изменить профиль"/>
                                                <Button mnemonicParsing="false" onAction="#onChangeSkin"
                                                        styleClass="secondary-button" text="Сменить скин"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <FlowPane hgap="18.0" prefWrapLength="980.0" vgap="18.0">
                                    <children>
                                        <VBox prefWidth="220.0" spacing="6.0" styleClass="metric-card, metric-card-compact">
                                            <children>
                                                <Label text="ID АККАУНТА" styleClass="label-muted"/>
                                                <Label fx:id="accountIdLabel" styleClass="metric-value-small" wrapText="true"/>
                                            </children>
                                        </VBox>
                                        <VBox prefWidth="180.0" spacing="6.0" styleClass="metric-card, metric-card-compact">
                                            <children>
                                                <Label text="РЕЖИМ ВХОДА" styleClass="label-muted"/>
                                                <Label text="через лаунчер" styleClass="metric-value-small"/>
                                            </children>
                                        </VBox>
                                        <VBox prefWidth="220.0" spacing="6.0" styleClass="metric-card, metric-card-compact">
                                            <children>
                                                <Label text="SERVER ID" styleClass="label-muted"/>
                                                <Label fx:id="launcherServerIdLabel" styleClass="metric-value-small" wrapText="true"/>
                                            </children>
                                        </VBox>
                                        <VBox spacing="6.0" styleClass="metric-card, metric-card-compact" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="ПАПКА ИГРЫ" styleClass="label-muted"/>
                                                <Label fx:id="launcherPathLabel" styleClass="metric-value-small" wrapText="true"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </FlowPane>

                                <FlowPane hgap="20.0" prefWrapLength="980.0" vgap="20.0" VBox.vgrow="ALWAYS">
                                    <children>
                                        <VBox prefWidth="300.0" spacing="16.0" styleClass="profile-card">
                                            <children>
                                                <Label text="Безопасность" styleClass="label-value"/>
                                                <Label text="Управление паролем и дополнительной защитой аккаунта."
                                                       styleClass="label-body" wrapText="true"/>
                                                <Label text="Сейчас здесь доступны базовые действия. Позже можно будет подключить 2FA."
                                                       styleClass="label-muted" wrapText="true"/>
                                                <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onChangePassword"
                                                        styleClass="secondary-button" text="Сменить пароль"/>
                                                <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onEnableTwoFactor"
                                                        styleClass="secondary-button" text="Подключить 2FA"/>
                                            </children>
                                        </VBox>

                                        <VBox prefWidth="300.0" spacing="16.0" styleClass="profile-card">
                                            <children>
                                                <Label text="Игровой профиль" styleClass="label-value"/>
                                                <Label text="Отсюда будет удобно открывать статистику, состояние персонажа и будущие серверные данные."
                                                       styleClass="label-body" wrapText="true"/>
                                                <Label text="Экран уже готов под дальнейшее расширение без перегрузки интерфейса."
                                                       styleClass="label-muted" wrapText="true"/>
                                                <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onOpenStats"
                                                        styleClass="secondary-button" text="Открыть статистику"/>
                                            </children>
                                        </VBox>

                                        <VBox prefWidth="300.0" spacing="16.0" styleClass="profile-card">
                                            <children>
                                                <Label text="Launcher и запуск" styleClass="label-value"/>
                                                <Label text="Здесь видно, к какому серверу и какой директории сейчас привязан ваш аккаунт."
                                                       styleClass="label-body" wrapText="true"/>
                                                <Label text="Если нужно поменять путь, manifest или Java-команду, переходите в настройки."
                                                       styleClass="label-muted" wrapText="true"/>
                                                <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onLauncherSettings"
                                                        styleClass="secondary-button" text="Открыть настройки запуска"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </FlowPane>
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </StackPane>
    </center>
</BorderPane>
