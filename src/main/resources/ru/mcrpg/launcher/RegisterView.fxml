<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="ru.mcrpg.launcher.RegisterController"
           prefHeight="900.0" prefWidth="1500.0" styleClass="account-root, auth-landing-root">
    <children>
        <BorderPane styleClass="auth-landing-shell">
            <top>
                <HBox alignment="CENTER_RIGHT" onMouseDragged="#dragWindow" onMousePressed="#captureWindowDrag"
                      spacing="12.0" styleClass="top-bar, auth-top-bar">
                    <padding>
                        <Insets bottom="14.0" left="24.0" right="24.0" top="18.0"/>
                    </padding>
                    <children>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="versionLabel" styleClass="top-meta" text="Версия"/>
                        <Button fx:id="minimizeWindowButton" mnemonicParsing="false" onAction="#minimizeWindow"
                                styleClass="window-button" text="_"/>
                        <Button fx:id="maximizeWindowButton" mnemonicParsing="false" onAction="#toggleMaximizeWindow"
                                styleClass="window-button" text="□"/>
                        <Button fx:id="closeWindowButton" mnemonicParsing="false" onAction="#closeWindow"
                                styleClass="window-button" text="X"/>
                    </children>
                </HBox>
            </top>

            <center>
                <VBox alignment="CENTER" spacing="18.0" styleClass="auth-landing-content">
                    <children>
                        <VBox alignment="CENTER" spacing="10.0" styleClass="auth-brand-block">
                            <children>
                                <HBox alignment="CENTER" spacing="18.0">
                                    <children>
                                        <StackPane fx:id="brandLogoPane" maxHeight="58.0" maxWidth="58.0"
                                                   minHeight="58.0" minWidth="58.0" prefHeight="58.0"
                                                   prefWidth="58.0" styleClass="brand-logo"/>
                                        <Label styleClass="auth-brand-title" text="ObsidianGate"/>
                                    </children>
                                </HBox>
                                <Label styleClass="auth-brand-subtitle" text="Регистрация игрового аккаунта"/>
                            </children>
                        </VBox>

                        <VBox maxWidth="640.0" prefWidth="640.0" spacing="20.0" styleClass="auth-card">
                            <children>
                                <VBox alignment="CENTER" spacing="10.0">
                                    <children>
                                        <HBox alignment="CENTER" spacing="8.0">
                                            <children>
                                                <Label styleClass="auth-card-title" text="Создать аккаунт"/>
                                                <Label styleClass="pixel-accent" text="■ ■"/>
                                            </children>
                                        </HBox>
                                        <Label styleClass="muted" text="Аккаунт нужен для запуска и входа на сервер."/>
                                    </children>
                                </VBox>

                                <VBox spacing="14.0" styleClass="auth-form">
                                    <children>
                                        <VBox spacing="8.0">
                                            <children>
                                                <Label styleClass="field-label" text="Ник"/>
                                                <TextField fx:id="usernameField" promptText="A-Za-z0-9_, 3-16 символов"
                                                           styleClass="auth-input"/>
                                            </children>
                                        </VBox>

                                        <VBox spacing="8.0">
                                            <children>
                                                <Label styleClass="field-label" text="Email"/>
                                                <TextField fx:id="emailField" promptText="you@example.com"
                                                           styleClass="auth-input"/>
                                            </children>
                                        </VBox>

                                        <VBox spacing="8.0">
                                            <children>
                                                <Label styleClass="field-label" text="Пароль"/>
                                                <PasswordField fx:id="passwordField" promptText="Минимум 8 символов"
                                                               styleClass="auth-input"/>
                                            </children>
                                        </VBox>

                                        <VBox spacing="8.0">
                                            <children>
                                                <Label styleClass="field-label" text="Повтор пароля"/>
                                                <PasswordField fx:id="confirmPasswordField"
                                                               promptText="Введите пароль еще раз"
                                                               styleClass="auth-input"/>
                                            </children>
                                        </VBox>

                                        <CheckBox fx:id="rulesCheck" text="Я принимаю правила сервера"/>
                                        <Label fx:id="statusLabel" styleClass="status-error" wrapText="true"/>

                                        <Button fx:id="registerButton" maxWidth="1.7976931348623157E308"
                                                mnemonicParsing="false" onAction="#onRegister"
                                                styleClass="auth-primary-button" text="Зарегистрироваться"/>

                                        <HBox alignment="CENTER" spacing="8.0">
                                            <children>
                                                <Label styleClass="muted" text="Уже есть аккаунт?"/>
                                                <Hyperlink fx:id="openLoginLink" onAction="#openLogin" text="Войти"/>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <Label styleClass="auth-footer-copy" text="© 2026 ObsidianGate. Все права защищены."/>
                    </children>
                </VBox>
            </center>
        </BorderPane>
    </children>
</StackPane>
