<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="ru.mcrpg.launcher.RegisterController" styleClass="account-root">
    <children>
        <ImageView fitWidth="1360.0" fitHeight="820.0" preserveRatio="false" opacity="0.66">
            <image>
                <Image url="@obsidiangate/images/backgrounds/hero_portal_background.png"/>
            </image>
        </ImageView>
        <Pane styleClass="auth-background-overlay"/>

        <BorderPane prefWidth="1360.0" prefHeight="820.0" styleClass="app-window">
            <top>
                <HBox alignment="CENTER_RIGHT" onMouseDragged="#dragWindow" onMousePressed="#captureWindowDrag"
                      spacing="12.0" styleClass="account-window-bar">
                    <padding>
                        <Insets top="24.0" right="30.0" bottom="0.0" left="30.0"/>
                    </padding>
                    <children>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="minimizeWindowButton" mnemonicParsing="false"
                                onAction="#minimizeWindow" styleClass="window-control"/>
                        <Button fx:id="closeWindowButton" mnemonicParsing="false"
                                onAction="#closeWindow" styleClass="window-control, window-control-close"/>
                    </children>
                </HBox>
            </top>

            <center>
                <HBox alignment="CENTER" spacing="32.0">
                    <padding>
                        <Insets top="8.0" right="48.0" bottom="40.0" left="48.0"/>
                    </padding>
                    <children>
                        <VBox maxWidth="480.0" prefWidth="480.0" spacing="20.0" styleClass="auth-side-card">
                            <children>
                                <Label text="Создай героя" styleClass="title-main"/>
                                <Label text="Регистрация нужна, чтобы сохранять прогресс, подключать серверный auth flow и работать с профилем прямо из launcher."
                                       wrapText="true" styleClass="label-body"/>
                                <HBox spacing="14.0">
                                    <children>
                                        <VBox spacing="8.0" styleClass="mini-stat-card" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Шаг 1" styleClass="mini-stat-title"/>
                                                <Label text="Придумайте никнейм и привяжите email для auth API."
                                                       wrapText="true" styleClass="mini-stat-copy"/>
                                            </children>
                                        </VBox>
                                        <VBox spacing="8.0" styleClass="mini-stat-card" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Шаг 2" styleClass="mini-stat-title"/>
                                                <Label text="После входа будут доступны sync, game ticket и профиль игрока."
                                                       wrapText="true" styleClass="mini-stat-copy"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                                <VBox spacing="14.0" styleClass="sidebar-footer-card">
                                    <padding>
                                        <Insets top="18.0" right="18.0" bottom="18.0" left="18.0"/>
                                    </padding>
                                    <children>
                                        <Label text="Зачем нужен аккаунт" styleClass="label-value"/>
                                        <Label text="Один аккаунт используется для launcher auth, сайта и серверной проверки входа."
                                               wrapText="true" styleClass="label-muted"/>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <VBox maxWidth="460.0" prefWidth="460.0" spacing="18.0" styleClass="auth-card">
                            <children>
                                <ImageView fitWidth="180.0" preserveRatio="true">
                                    <image>
                                        <Image url="@obsidiangate/images/logo/obsidiangate_logo_transparent_soft.png"/>
                                    </image>
                                </ImageView>
                                <VBox spacing="8.0">
                                    <children>
                                        <Label text="NEW ACCOUNT" styleClass="screen-kicker"/>
                                        <Label text="Регистрация" styleClass="auth-title"/>
                                        <Label text="Создайте аккаунт ObsidianGate и подключитесь к RPG-миру через launcher."
                                               wrapText="true" styleClass="auth-subtitle"/>
                                    </children>
                                </VBox>

                                <VBox spacing="12.0">
                                    <children>
                                        <VBox spacing="7.0">
                                            <children>
                                                <Label text="Никнейм" styleClass="field-label"/>
                                                <TextField fx:id="usernameField" promptText="Например: Arcanist_42"
                                                           styleClass="auth-field"/>
                                            </children>
                                        </VBox>
                                        <VBox spacing="7.0">
                                            <children>
                                                <Label text="Email" styleClass="field-label"/>
                                                <TextField fx:id="emailField" promptText="you@example.com"
                                                           styleClass="auth-field"/>
                                            </children>
                                        </VBox>
                                        <VBox spacing="7.0">
                                            <children>
                                                <Label text="Пароль" styleClass="field-label"/>
                                                <PasswordField fx:id="passwordField" promptText="Минимум 8 символов"
                                                               styleClass="auth-field"/>
                                            </children>
                                        </VBox>
                                        <VBox spacing="7.0">
                                            <children>
                                                <Label text="Повторите пароль" styleClass="field-label"/>
                                                <PasswordField fx:id="confirmPasswordField" promptText="Введите пароль еще раз"
                                                               styleClass="auth-field"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>

                                <CheckBox fx:id="rulesCheck"
                                          text="Я принимаю правила сервера и пользовательское соглашение"
                                          wrapText="true"/>

                                <Label fx:id="statusLabel" styleClass="status-error" wrapText="true"/>

                                <Button fx:id="registerButton" maxWidth="Infinity" mnemonicParsing="false"
                                        onAction="#onRegister" styleClass="primary-button"
                                        text="Создать аккаунт"/>

                                <Region styleClass="divider"/>

                                <HBox alignment="CENTER" spacing="8.0">
                                    <children>
                                        <Label text="Уже есть аккаунт?" styleClass="label-muted"/>
                                        <Hyperlink fx:id="openLoginLink" text="Войти"
                                                   onAction="#openLogin" styleClass="link-button"/>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </center>
        </BorderPane>
    </children>
</StackPane>
